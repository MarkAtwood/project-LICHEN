{
  "description": "LICHEN link-layer frame parsing test vectors",
  "reference": "spec/02-physical-link.md section 4",
  "format": {
    "input_hex": "Complete frame as hex string, including length byte",
    "expected": "Parsed frame fields, or error: true for invalid frames"
  },
  "vectors": [
    {
      "name": "minimal_valid_frame",
      "description": "Broadcast frame with no payload, 32-bit MIC",
      "input_hex": "0800011234aabbccdd",
      "expected": {
        "addr_mode": 0,
        "mic_length": 0,
        "signature_present": false,
        "encrypted": false,
        "epoch": 1,
        "seqnum": 4660,
        "dst_addr_hex": "",
        "payload_hex": "",
        "mic_hex": "aabbccdd"
      }
    },
    {
      "name": "frame_with_short_address",
      "description": "Frame with 16-bit destination address and payload",
      "input_hex": "0c0142567812344869deadbeef",
      "expected": {
        "addr_mode": 1,
        "mic_length": 0,
        "signature_present": false,
        "encrypted": false,
        "epoch": 66,
        "seqnum": 22136,
        "dst_addr_hex": "1234",
        "payload_hex": "4869",
        "mic_hex": "deadbeef"
      }
    },
    {
      "name": "frame_with_signature",
      "description": "Frame with signature_present flag set, payload contains 48-byte Schnorr-48 signature",
      "input_hex": "3a2105abcdbeef55555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555511223344",
      "expected": {
        "addr_mode": 1,
        "mic_length": 0,
        "signature_present": true,
        "encrypted": false,
        "epoch": 5,
        "seqnum": 43981,
        "dst_addr_hex": "beef",
        "payload_hex": "555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555555",
        "mic_hex": "11223344",
        "notes": "Payload is exactly LICHEN_SIG_LEN (48) bytes when signature_present is true"
      }
    },
    {
      "name": "frame_with_64bit_mic",
      "description": "Extended address (EUI-64) with 64-bit MIC",
      "input_hex": "1806ff0001010203040506070854455354deadbeefcafebabe",
      "expected": {
        "addr_mode": 2,
        "mic_length": 1,
        "signature_present": false,
        "encrypted": false,
        "epoch": 255,
        "seqnum": 1,
        "dst_addr_hex": "0102030405060708",
        "payload_hex": "54455354",
        "mic_hex": "deadbeefcafebabe"
      }
    },
    {
      "name": "encrypted_frame",
      "description": "Encrypted frame with extended address and 64-bit MIC",
      "input_hex": "1846102000aabbccddeeff001144415441123456789abcdef0",
      "expected": {
        "addr_mode": 2,
        "mic_length": 1,
        "signature_present": false,
        "encrypted": true,
        "epoch": 16,
        "seqnum": 8192,
        "dst_addr_hex": "aabbccddeeff0011",
        "payload_hex": "44415441",
        "mic_hex": "123456789abcdef0"
      }
    },
    {
      "name": "max_size_frame",
      "description": "Maximum frame size (255-byte body), broadcast with 32-bit MIC",
      "input_hex": "",
      "expected": {
        "addr_mode": 0,
        "mic_length": 0,
        "signature_present": false,
        "encrypted": false,
        "epoch": 0,
        "seqnum": 0,
        "dst_addr_hex": "",
        "payload_len": 247,
        "mic_hex": "ffffffff",
        "notes": "Payload is 247 bytes of 0xAA (255 - 4 header - 4 MIC)"
      }
    },
    {
      "name": "truncated_frame",
      "description": "Length field claims 20 bytes but only 8 body bytes present",
      "input_hex": "1400011234aabbccdd",
      "expected": {
        "error": true,
        "error_type": "length_mismatch"
      }
    },
    {
      "name": "invalid_reserved_bit",
      "description": "LLSec reserved bit 7 is set (must be 0)",
      "input_hex": "0880011234aabbccdd",
      "expected": {
        "error": true,
        "error_type": "reserved_bit_set"
      }
    },
    {
      "name": "frame_too_short",
      "description": "Frame body too short for minimum header fields",
      "input_hex": "020001",
      "expected": {
        "error": true,
        "error_type": "frame_too_short"
      }
    },
    {
      "name": "empty_frame",
      "description": "Zero-length frame (no data at all)",
      "input_hex": "",
      "expected": {
        "error": true,
        "error_type": "empty_frame"
      }
    }
  ]
}
