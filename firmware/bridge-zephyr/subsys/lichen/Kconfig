# LICHEN L2 network integration options
# These extend the base LICHEN Kconfig from lichen/subsys/lichen/Kconfig
# with Zephyr network stack integration.

menuconfig LICHEN
	bool "LICHEN mesh networking stack"
	help
	  Enable the LICHEN IPv6 mesh networking stack over LoRa.

if LICHEN

config LICHEN_TIME_BUILD_EPOCH_UNIX
	int "Deterministic firmware build epoch floor"
	default 1700000000
	range 1 2147483647
	help
	  Deterministic Unix timestamp used as the minimum plausible wall-clock
	  value. Production builds must set this from reproducible build
	  metadata, preferably SOURCE_DATE_EPOCH, or an explicit release epoch.

choice LICHEN_TIME_BUILD_EPOCH_SOURCE
	prompt "Firmware build epoch metadata source"
	default LICHEN_TIME_BUILD_EPOCH_SOURCE_FIXED
	help
	  Records where CONFIG_LICHEN_TIME_BUILD_EPOCH_UNIX came from.

config LICHEN_TIME_BUILD_EPOCH_SOURCE_FIXED
	bool "Fixed Kconfig default or test override"

config LICHEN_TIME_BUILD_EPOCH_SOURCE_DATE_EPOCH
	bool "SOURCE_DATE_EPOCH"

config LICHEN_TIME_BUILD_EPOCH_SOURCE_RELEASE
	bool "Explicit release epoch"

config LICHEN_TIME_BUILD_EPOCH_SOURCE_DEVELOPER_GENERATED
	bool "Explicit developer generated timestamp"

config LICHEN_TIME_BUILD_EPOCH_SOURCE_DEVELOPER_FIXED
	bool "Explicit developer fixed timestamp"

endchoice

config LICHEN_LORA_L2
	bool "LICHEN LoRa L2 driver"
	depends on LORA
	depends on NETWORKING
	depends on NET_IPV6
	depends on LICHEN_IPV6
	select LICHEN_LINK
	select HWINFO
	select TINYCRYPT
	select TINYCRYPT_AES
	select TINYCRYPT_AES_CCM
	default y
	help
	  Enable the LICHEN LoRa L2 driver. This provides low-level LoRa
	  radio access including TX/RX threads and EUI-64 generation.
	  It is only supported through the full LICHEN_L2 Zephyr network
	  interface path; standalone LoRa mode is disabled because it could
	  receive frames without parsing, SCHC decompression, or IPv6 ingress.

config LICHEN_LORA_L2_LOG_LEVEL
	int "LICHEN LoRa L2 log level"
	depends on LICHEN_LORA_L2
	default 3
	range 0 4
	help
	  Log level for LICHEN LoRa L2 driver.
	  0 = Off, 1 = Error, 2 = Warning, 3 = Info, 4 = Debug

config LICHEN_LORA_L2_RX_STACK_SIZE
	int "LICHEN LoRa L2 RX thread stack size"
	depends on LICHEN_LORA_L2
	default 2048
	help
	  Stack size for the LoRa L2 RX thread.

config LICHEN_LORA_L2_RX_PRIORITY
	int "LICHEN LoRa L2 RX thread priority"
	depends on LICHEN_LORA_L2
	default 7
	help
	  Priority for the LoRa L2 RX thread. Lower numbers = higher priority.

config LICHEN_LORA_L2_RX_TIMEOUT_MS
	int "LoRa RX timeout in milliseconds"
	depends on LICHEN_LORA_L2
	default 1000
	range 100 10000
	help
	  Timeout for lora_recv() calls in the RX thread. This affects:
	  - How often the thread checks the running flag (lower = more responsive stop)
	  - Stop latency (worst case: 100ms + this timeout before thread joins)
	  - CPU overhead (lower = more loop iterations, but overhead is minimal)

	  Lower values (500-1000ms) provide faster stop() responsiveness.
	  Higher values (3000-5000ms) may save power on some platforms by
	  reducing wakeup frequency, but slow down disable/enable cycles.

	  Default 1000ms balances responsiveness with low overhead.

config LICHEN_LORA_FREQUENCY
	int "LoRa frequency in Hz"
	depends on LICHEN_LORA_L2
	default 915000000
	range 150000000 960000000
	help
	  LoRa carrier frequency in Hz. Must comply with regional regulations.
	  Common ISM bands: 915000000 (US), 868000000 (EU), 433000000 (Asia).
	  Range: 150-960 MHz covers all LoRa-capable frequency bands.

config LICHEN_LORA_TX_POWER
	int "LoRa TX power in dBm"
	depends on LICHEN_LORA_L2
	default 14
	range 0 22
	help
	  LoRa transmit power in dBm. Default 14 dBm is safe worldwide.
	  Higher values may violate regional regulations. Maximum 22 dBm.

config LICHEN_L2
	bool "LICHEN Zephyr L2 network interface"
	depends on LICHEN_LORA_L2
	depends on LICHEN_LINK
	depends on NETWORKING
	depends on NET_IPV6
	depends on LICHEN_IPV6
	default y if NET_IPV6
	help
	  Register LICHEN as a Zephyr L2 network interface so the IPv6
	  stack routes packets through it. This implements the net_l2
	  callbacks (recv, send, enable, flags) and bridges IPv6 packets
	  to the LoRa radio via SCHC compression and LICHEN framing.

	  When enabled, this creates a network device called "LICHEN" that
	  appears as a standard Zephyr network interface, allowing IPv6
	  applications to send/receive packets over LoRa transparently.

config LICHEN_L2_LOG_LEVEL
	int "LICHEN L2 log level"
	depends on LICHEN_L2
	default 3
	range 0 4
	help
	  Log level for LICHEN Zephyr L2 interface.
	  0 = Off, 1 = Error, 2 = Warning, 3 = Info, 4 = Debug

config LICHEN_UTIL_LOG_LEVEL
	int "LICHEN util log level"
	depends on LICHEN
	default 1
	range 0 4
	help
	  Log level for LICHEN utility functions (SHA-256, etc.).
	  0 = Off, 1 = Error, 2 = Warning, 3 = Info, 4 = Debug

config LICHEN_L2_RX_ALLOC_TIMEOUT_MS
	int "RX packet allocation timeout (ms)"
	depends on LICHEN_L2
	default 50
	range 0 1000
	help
	  Timeout in milliseconds for net_pkt_rx_alloc_with_buffer().
	  Controls how long the RX path waits for a network buffer.

	  Tradeoffs:
	  - Lower values (0-10ms): Faster failure under memory pressure,
	    but may drop packets that could have succeeded with a brief wait.
	  - Higher values (50-100ms): Better allocation success rate,
	    but may stall RX processing and cause radio buffer overruns.

	  For LoRa's low data rate (~300 bps at SF10), 50ms is reasonable:
	  a full 255-byte frame takes ~6.8 seconds to transmit, so brief
	  allocation delays don't cause radio-level issues. However, if your
	  application has tighter real-time constraints, reduce this value.

	  If you see "Failed to allocate RX packet" log messages, consider
	  increasing this value or adding more NET_BUF_RX buffers.

	  Set to 0 for immediate failure (K_NO_WAIT).

config LICHEN_IPV6
	bool "LICHEN IPv6 address utilities"
	default y
	help
	  Enable LICHEN IPv6 address utilities. This handles:
	  - Link-local address derivation from EUI-64
	  - ULA address construction
	  - GUA address construction
	  These are standalone utilities that work with or without
	  Zephyr's full networking stack.

config LICHEN_IPV6_ULA_PREFIX
	string "Default ULA prefix"
	depends on LICHEN_IPV6
	default "fd00:lich:en00::"
	help
	  Default ULA prefix used when no DODAG root provides one.
	  Format: fd00:xxxx:xxxx:: (must be in fd00::/8)

	  Note: Kconfig cannot validate string format at compile time.
	  Runtime validation in lichen_make_ula() enforces the fd00::/8
	  requirement and returns -EINVAL for invalid prefixes.

endif # LICHEN
