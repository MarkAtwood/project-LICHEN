/*
 * LilyGo T-Deck device tree overlay for LICHEN bridge
 *
 * ESP32-S3 + SX1262 LoRa
 *
 * SX1262 SPI pins (shared bus):
 *   SCK  = GPIO40
 *   MISO = GPIO38
 *   MOSI = GPIO41
 *   NSS  = GPIO9
 *
 * SX1262 control pins:
 *   RESET = GPIO17
 *   BUSY  = GPIO13
 *   DIO1  = GPIO45 (gpio1 pin 13)
 *
 * Note: T-Deck shares SPI bus with display (ST7789) and SD card.
 * Each device uses separate chip select.
 */

#include <zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h>

/ {
	chosen {
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
	};

	aliases {
		lora0 = &lora;
	};
};

&pinctrl {
	/* SPI2 for SX1262 (shared with display/SD) */
	spim2_default: spim2_default {
		group1 {
			pinmux = <SPIM2_MISO_GPIO38>,
				 <SPIM2_SCLK_GPIO40>;
		};
		group2 {
			pinmux = <SPIM2_MOSI_GPIO41>;
			output-low;
		};
	};
};

&spi2 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-0 = <&spim2_default>;
	pinctrl-names = "default";
	cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;  /* NSS = GPIO9 */

	lora: sx1262@0 {
		compatible = "semtech,sx1262";
		reg = <0>;
		spi-max-frequency = <8000000>;
		reset-gpios = <&gpio0 17 GPIO_ACTIVE_LOW>;  /* RESET = GPIO17 */
		busy-gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;  /* BUSY = GPIO13 */
		dio1-gpios = <&gpio1 13 GPIO_ACTIVE_HIGH>;  /* DIO1 = GPIO45 */
		/* DIO2 controls RF switch internally */
		dio2-tx-enable;
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};
