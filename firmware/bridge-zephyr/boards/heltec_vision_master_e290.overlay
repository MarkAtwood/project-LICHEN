/*
 * STALE bridge fragment: heltec_vision_master_e290 has no canonical Zephyr
 * board target (no matching board in Zephyr tree, lichen/boards/, or HWMv2
 * selector). Retired per project-LICHEN-2u26.3 / 2u26 (bridge mapping only).
 * Do not use for builds. See docs/firmware-board-capability-matrix.md.
 *
 * Heltec Vision Master E290 device tree overlay for LICHEN bridge
 *
 * ESP32-S3 + SX1262 LoRa + 2.9" E-ink display
 *
 * SX1262 SPI pins (same as E213):
 *   SCK  = GPIO9
 *   MISO = GPIO11
 *   MOSI = GPIO10
 *   NSS  = GPIO8
 *
 * SX1262 control pins (same as E213):
 *   RESET = GPIO12
 *   BUSY  = GPIO13 (active high, directly wired to DIO2)
 *   DIO1  = GPIO14
 *
 * E-ink display (not used by bridge, pins differ from E213):
 *   CS   = GPIO3
 *   BUSY = GPIO6
 *   DC   = GPIO4
 *   RES  = GPIO5
 *   SCLK = GPIO2
 *   MOSI = GPIO1
 *
 * Vext power control = GPIO18 (active high)
 * ADC control = GPIO46
 * Battery ADC = GPIO7
 * LED power = GPIO45
 * User button = GPIO21
 */

#include <zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h>

/ {
	chosen {
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
	};

	aliases {
		lora0 = &lora;
	};
};

&pinctrl {
	/* SPI2 for SX1262 */
	spim2_default: spim2_default {
		group1 {
			pinmux = <SPIM2_MISO_GPIO11>,
				 <SPIM2_SCLK_GPIO9>;
		};
		group2 {
			pinmux = <SPIM2_MOSI_GPIO10>;
			output-low;
		};
	};
};

&usb_serial {
	status = "okay";
};

&spi2 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-0 = <&spim2_default>;
	pinctrl-names = "default";
	cs-gpios = <&gpio0 8 GPIO_ACTIVE_LOW>;  /* NSS = GPIO8 */

	lora: sx1262@0 {
		compatible = "semtech,sx1262";
		reg = <0>;
		spi-max-frequency = <8000000>;
		reset-gpios = <&gpio0 12 GPIO_ACTIVE_LOW>;  /* RESET = GPIO12 */
		busy-gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;  /* BUSY = GPIO13 */
		dio1-gpios = <&gpio0 14 GPIO_ACTIVE_HIGH>;  /* DIO1 = GPIO14 */
		/* DIO2 controls RF switch internally on SX1262 */
		dio2-tx-enable;
	};
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};
