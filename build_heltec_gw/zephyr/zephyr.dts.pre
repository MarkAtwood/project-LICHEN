# 13 "/mnt/lichen-zephyr/work/project-LICHEN-worker2/lichen/boards/heltec/heltec_wifi_lora32_v3/heltec_wifi_lora32_v3-pinctrl.dtsi" 2

&pinctrl {

 uart0_default: uart0_default {
  group1 {
   pinmux = <(((43 & 0x3FU) << 0U) | ((0x1FFU & 0x1FFU) << 6U) | ((12 & 0x1FFU) << 15U))>;
   output-high;
  };
  group2 {
   pinmux = <(((44 & 0x3FU) << 0U) | ((12 & 0x1FFU) << 6U) | ((0x1FFU & 0x1FFU) << 15U))>;
   bias-pull-up;
  };
 };





 i2c0_default: i2c0_default {
  group1 {
   pinmux = <(((17 & 0x3FU) << 0U) | ((90 & 0x1FFU) << 6U) | ((90 & 0x1FFU) << 15U))>,
     <(((18 & 0x3FU) << 0U) | ((89 & 0x1FFU) << 6U) | ((89 & 0x1FFU) << 15U))>;
   bias-pull-up;
   drive-open-drain;
   output-high;
  };
 };






 spim2_default: spim2_default {
  group1 {
   pinmux = <(((11 & 0x3FU) << 0U) | ((102 & 0x1FFU) << 6U) | ((0x1FFU & 0x1FFU) << 15U))>,
     <(((9 & 0x3FU) << 0U) | ((0x1FFU & 0x1FFU) << 6U) | ((101 & 0x1FFU) << 15U))>,
     <(((8 & 0x3FU) << 0U) | ((0x1FFU & 0x1FFU) << 6U) | ((110 & 0x1FFU) << 15U))>;
  };
  group2 {
   pinmux = <(((10 & 0x3FU) << 0U) | ((0x1FFU & 0x1FFU) << 6U) | ((103 & 0x1FFU) << 15U))>;
   output-low;
  };
 };
};
