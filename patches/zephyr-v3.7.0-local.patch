+/*
+ * The CDC ACM workqueue runs at cooperative priority. A handler that
+ * cannot make progress (CDC_ACM_LOCK held by a preemptible thread in
+ * poll_out/poll_in, or the buf pool exhausted) must NOT resubmit itself
+ * immediately: the immediate re-run starves every preemptible thread —
+ * including the lock holder — and the retry spins forever. Retry paths
+ * therefore back off by one tick so lower-priority threads can run;
+ * fresh-event paths still schedule with no delay.
+ */
+static ALWAYS_INLINE int cdc_acm_work_schedule(struct k_work_delayable *work,
+					       k_timeout_t delay)
+{
+	return k_work_schedule_for_queue(&cdc_acm_work_q, work, delay);
+}
+
 static ALWAYS_INLINE bool check_wq_ctx(const struct device *dev)
 {
 	return k_current_get() == k_work_queue_thread_get(&cdc_acm_work_q);
@@ -227,7 +242,7 @@ static int usbd_cdc_acm_request(struct usbd_class_data *const c_data,
 		LOG_HEXDUMP_INF(buf->data, buf->len, "");
 		done = ring_buf_put(data->rx_fifo.rb, buf->data, buf->len);
 		if (done && data->cb) {
