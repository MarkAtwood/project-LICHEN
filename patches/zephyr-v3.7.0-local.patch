diff --git a/drivers/lora/sx126x.c b/drivers/lora/sx126x.c
index aeb9efe8..63e28264 100644
--- a/drivers/lora/sx126x.c
+++ b/drivers/lora/sx126x.c
@@ -364,7 +364,14 @@ void SX126xSetRfTxPower(int8_t power)
 
 void SX126xWaitOnBusy(void)
 {
+	int64_t deadline = k_uptime_get() + 500;
+
 	while (sx126x_is_busy(&dev_data)) {
+		if (k_uptime_get() > deadline) {
+			LOG_WRN("SX126x BUSY stuck — hard reset");
+			SX126xReset();
+			return;
+		}
 		k_sleep(K_MSEC(1));
 	}
 }
diff --git a/drivers/usb/device/usb_dc_nrfx.c b/drivers/usb/device/usb_dc_nrfx.c
index 49cb4621..1bc3074a 100644
--- a/drivers/usb/device/usb_dc_nrfx.c
+++ b/drivers/usb/device/usb_dc_nrfx.c
@@ -274,6 +274,14 @@ static struct nrf_usbd_ctx usbd_ctx = {
 	.ready = false,
 };
 
+/*
+ * Set when usb_dc_attach() finds USB already in READY state (USB-enabled
+ * bootloader case) and has started HFXO + enabled the USBD peripheral via
+ * the ATTACHED work handler, but deferred the POWERED event (D+ pullup) until
+ * EP0 is fully configured.  Cleared once the POWERED event is submitted.
+ */
+static bool usbd_powered_pending;
+
 static inline struct nrf_usbd_ctx *get_usbd_ctx(void)
 {
 	return &usbd_ctx;
@@ -687,6 +695,13 @@ static inline void usbd_work_process_pwr_events(struct usbd_pwr_event *pwr_evt)
 		break;
 
 	case USBD_POWERED:
+		/* If usbd_powered_pending is set, EP0 is not yet configured —
+		 * skip D+ pullup now; usb_dc_ep_enable(EP0_IN) will fire a
+		 * deferred POWERED event after EP0 callbacks are registered.
+		 */
+		if (usbd_powered_pending) {
+			break;
+		}
 		usbd_enable_endpoints(ctx);
 		nrf_usbd_common_start(IS_ENABLED(CONFIG_USB_DEVICE_SOF));
 		ctx->ready = true;
@@ -1284,6 +1299,40 @@ int usb_dc_attach(void)
 	IRQ_CONNECT(DT_INST_IRQN(0), DT_INST_IRQ(0, priority),
 		    nrfx_isr, nrf_usbd_common_irq_handler, 0);
 
+	/* Check USB state before enabling power events.  When booting after a
+	 * USB-enabled bootloader (e.g. Adafruit UF2), VBUS is already present
+	 * and EVENTS_USBDETECTED/EVENTS_USBPWRRDY are latched in the POWER
+	 * peripheral.  nrfx_power_usbevt_enable() below immediately fires the
+	 * POWER_CLOCK IRQ which queues both ATTACHED and POWERED work items.
+	 * The work queue (priority -1) preempts the main thread as soon as
+	 * usbd_work_schedule() is called.  POWERED calls
+	 * nrf_usbd_common_start() → USBPULLUP=1, which requires HFXO to be
+	 * running for correct USB bit timing.  Start and wait for HFXO here,
+	 * before enabling events, so it is already on when POWERED fires.
+	 *
+	 * Race fix: if VBUS is already in READY state, set usbd_powered_pending
+	 * BEFORE enabling events so that the ghost POWERED work item (which will
+	 * preempt this thread via the high-priority work queue) skips
+	 * nrf_usbd_common_start().  D+ will not go high until EP0 is fully
+	 * configured by usb_enable() and usb_dc_ep_enable(EP0_IN) fires the
+	 * deferred POWERED event.  Without this, the null EP0 callback causes a
+	 * hard fault on the first SETUP packet from the host.
+	 */
+	nrfx_power_usb_state_t usb_status = nrfx_power_usbstatus_get();
+	if (usb_status != NRFX_POWER_USB_STATE_DISCONNECTED) {
+		int clk_result;
+
+		(void)hfxo_start(ctx);
+		while (sys_notify_fetch_result(&ctx->hfxo_cli.notify,
+					       &clk_result) != 0) {
+			k_busy_wait(10);
+		}
+	}
+
+	if (usb_status == NRFX_POWER_USB_STATE_READY) {
+		usbd_powered_pending = true;
+	}
+
 	nrfx_power_usbevt_enable();
 
 	ret = eps_ctx_init();
@@ -1291,21 +1340,30 @@ int usb_dc_attach(void)
 		ctx->attached = true;
 	}
 
+	/* Process any events queued by the POWER IRQ that fired inside
+	 * nrfx_power_usbevt_enable() above (ghost ATTACHED + POWERED from
+	 * latched hardware events).
+	 */
 	if (!k_fifo_is_empty(&usbd_evt_fifo)) {
 		usbd_work_schedule();
 	}
 
-	if (nrfx_power_usbstatus_get() != NRFX_POWER_USB_STATE_DISCONNECTED) {
-		/* USBDETECTED event is be generated on cable attachment and
-		 * when cable is already attached during reset, but not when
-		 * the peripheral is re-enabled.
-		 * When USB-enabled bootloader is used, target application
-		 * will not receive this event and it needs to be generated
-		 * again here.
-		 */
+	/* Manual replay for DETECTED in case the hardware events were already
+	 * cleared before nrfx_power_usbevt_enable() ran (e.g. VBUS arrived
+	 * during boot before the interrupt mask was enabled).
+	 */
+	if (usb_status != NRFX_POWER_USB_STATE_DISCONNECTED) {
 		usb_dc_power_event_handler(NRFX_POWER_USB_EVT_DETECTED);
 	}
 
+	/* If USBD is not yet ready (no ghost POWERED event fired D+ high),
+	 * defer the POWERED event to usb_dc_ep_enable(EP0_IN) so that EP0 is
+	 * fully configured before D+ goes high.
+	 */
+	if (usb_status == NRFX_POWER_USB_STATE_READY && !ctx->ready) {
+		usbd_powered_pending = true;
+	}
+
 	return ret;
 }
 
@@ -1570,6 +1628,17 @@ int usb_dc_ep_enable(const uint8_t ep)
 		nrf_usbd_common_ep_enable(ep_addr_to_nrfx(ep));
 	}
 
+	/* EP0_IN is the last endpoint enabled by usb_enable().  If USB was
+	 * already powered at attach time but the ghost POWERED event from the
+	 * POWER IRQ did not fire (e.g. VBUS arrived between power-on and the
+	 * interrupt mask being enabled), fire the deferred POWERED now so D+
+	 * goes high with EP0 fully configured.
+	 */
+	if (usbd_powered_pending && ep == USB_CONTROL_EP_IN) {
+		usbd_powered_pending = false;
+		usb_dc_power_event_handler(NRFX_POWER_USB_EVT_READY);
+	}
+
 	return 0;
 }
 
diff --git a/drivers/usb/udc/udc_nrf.c b/drivers/usb/udc/udc_nrf.c
index f02dfcdc..9aff13cb 100644
--- a/drivers/usb/udc/udc_nrf.c
+++ b/drivers/usb/udc/udc_nrf.c
@@ -71,6 +71,9 @@ static struct udc_ep_config ep_cfg_out[CFG_EPOUT_CNT + CFG_EP_ISOOUT_CNT + 1];
 static struct udc_ep_config ep_cfg_in[CFG_EPIN_CNT + CFG_EP_ISOIN_CNT + 1];
 static bool udc_nrf_setup_rcvd;
 const static struct device *udc_nrf_dev;
+/* Set by the READY power event if it fires before nrf_usbd_common_enable()
+ * (ghost event from a USB-active bootloader). Consumed in udc_nrf_enable(). */
+static bool udc_nrf_powered_pending;
 
 struct udc_nrf_config {
 	clock_control_subsys_t clock;
@@ -474,7 +477,13 @@ static void udc_nrf_power_handler(nrfx_power_usb_evt_t pwr_evt)
 		break;
 	case NRFX_POWER_USB_EVT_READY:
 		LOG_DBG("POWER event ready");
-		nrf_usbd_common_start(true);
+		if (nrf_usbd_common_is_enabled()) {
+			nrf_usbd_common_start(true);
+		} else {
+			/* Ghost event from a USB-active bootloader: driver not yet
+			 * initialized. Defer D+ pullup to udc_nrf_enable(). */
+			udc_nrf_powered_pending = true;
+		}
 		break;
 	case NRFX_POWER_USB_EVT_REMOVED:
 		LOG_DBG("POWER event removed");
@@ -664,6 +673,16 @@ static int udc_nrf_enable(const struct device *dev)
 	nrf_usbd_common_enable();
 	irq_unlock(key);
 
+	/* Assert D+ pullup unconditionally.  Three cases:
+	 * (a) Ghost READY fired before enable: udc_nrf_powered_pending was set,
+	 *     we call start here and clear the flag.
+	 * (b) Bootloader already cleared EVENTS_USBPWRRDY: no ghost fires at
+	 *     all, so udc_nrf_powered_pending stays false — we still call start.
+	 * (c) Normal hot-plug: READY fires after enable, handler calls start.
+	 *     Calling it again here is a harmless no-op (same register writes). */
+	udc_nrf_powered_pending = false;
+	nrf_usbd_common_start(true);
+
 	return 0;
 }
 
diff --git a/subsys/usb/device_next/class/usbd_cdc_acm.c b/subsys/usb/device_next/class/usbd_cdc_acm.c
