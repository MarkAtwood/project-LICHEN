menuconfig SCHC
	bool "Static Context Header Compression"
	help
	  Enable the generic RFC 8724 SCHC profile dispatch module.

if SCHC

config SCHC_LOG_LEVEL
	int "SCHC log level"
	default 3
	range 0 4
	help
	  Log level for the generic SCHC subsystem:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

endif # SCHC
