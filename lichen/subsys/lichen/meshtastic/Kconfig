menuconfig LICHEN_MESHTASTIC_CODEC
	bool "Meshtastic app-compat bounded protobuf codec"
	depends on LICHEN
	help
	  Enable the bounded no-allocation protobuf subset used by the
	  Meshtastic app compatibility adapter. The schema source is
	  meshtastic/protobufs commit 032b7dfd68e875c4323e6ac67590c6fc616b1714,
	  with PortNum values refreshed against
	  aa53c96b79d9cb49a38e71fc2bc9c46cec1fd7c6.

if LICHEN_MESHTASTIC_CODEC

config LICHEN_MESHTASTIC_ADAPTER
	bool "Meshtastic app-compat dispatcher"
	help
	  Enable the board-agnostic Meshtastic app adapter dispatcher. It accepts
	  raw ToRadio protobuf values, optionally reassembles serial StreamAPI
	  frames for non-BLE transports, and emits bounded FromRadio protobuf
	  responses through caller-provided transport callbacks.

config LICHEN_MESHTASTIC_MAX_TO_RADIO
	int "Maximum ToRadio protobuf value size"
	default 504
	range 1 504
	help
	  Maximum raw ToRadio protobuf value accepted from BLE. This follows
	  the generated Meshtastic firmware ToRadio_size budget.

config LICHEN_MESHTASTIC_MAX_FROM_RADIO
	int "Maximum FromRadio protobuf value size"
	default 510
	range 1 510
	help
	  Maximum raw FromRadio protobuf value emitted to BLE. This follows
	  the generated Meshtastic firmware FromRadio_size budget.

config LICHEN_MESHTASTIC_NODEDB_MAX_PEERS
	int "Maximum Meshtastic NodeDB peer records per sync"
	default 3
	range 1 3
	help
	  Maximum number of peer snapshots copied into one Meshtastic NodeDB
	  sync response. The adapter always emits self first, then up to this
	  many deterministic peer NodeInfo records after collision filtering.
	  The default gateway FromRadio queue can hold one queued heartbeat plus
	  a full static-and-NodeDB sync at this cap.

config LICHEN_MESHTASTIC_POSITION_EPOCH_FLOOR_UNIX
	int "Meshtastic Position timestamp epoch floor"
	default LICHEN_TIME_BUILD_EPOCH_UNIX if LICHEN_HAL
	default 1700000000
	range 1 2147483647
	help
	  Minimum plausible Unix timestamp accepted from Meshtastic Position
	  time/timestamp fields by the standalone adapter parser. Gateway
	  firmware defaults this to the firmware build epoch floor through the
	  HAL time-provider Kconfig. Adapter-only builds use the deterministic
	  fallback so protobuf policy tests remain stable without selecting HAL.

config LICHEN_MESHTASTIC_POSITION_MAX_FUTURE_SKEW
	int "Meshtastic Position max future skew seconds"
	default 630720000
	range 3600 2147483647
	help
	  Maximum skew from epoch floor before a position timestamp is rejected as future. Default ~20 years.

endif # LICHEN_MESHTASTIC_CODEC

