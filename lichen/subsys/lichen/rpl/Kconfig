# LICHEN RPL routing Kconfig

menuconfig LICHEN_RPL
	bool "LICHEN RPL routing"
	depends on LICHEN
	select NET_IPV6_NBR_CACHE
	select NET_ROUTE
	help
	  Enable RPL (RFC 6550) routing for DODAG mesh formation.
	  Provides upward routing via preferred parents and downward
	  routing via source routes (non-storing mode).

if LICHEN_RPL

config LICHEN_RPL_MRHOF
	bool "MRHOF objective function"
	default y
	help
	  Use Minimum Rank with Hysteresis Objective Function (MRHOF)
	  for parent selection (RFC 6719). MRHOF selects parents based
	  on ETX link quality with hysteresis to prevent flapping.

config LICHEN_RPL_MAX_PARENTS
	int "Maximum parent candidates"
	default 4
	range 2 8
	help
	  Maximum number of parent candidates tracked per DODAG and retained
	  per DAO target. More parents improves resilience but multiplies the
	  root-state memory used by every configured route.

config LICHEN_RPL_MAX_ROUTES
	int "Maximum routing table entries"
	default 32
	range 1 64
	help
	  Maximum number of target routes in the routing table.
	  Only relevant for root nodes in non-storing mode. The default root
	  state uses approximately 15 KiB before thread stacks and packet buffers.

config LICHEN_RPL_MAX_ACTIVE_DAO_CANDIDATES
	int "Maximum active DAO candidates"
	default 32
	range 1 64
	help
	  Maximum aggregate number of active target-to-parent candidates retained
	  by a root. A grouped DAO that would exceed this limit is rejected atomically.

config LICHEN_RPL_TRICKLE_IMIN_MS
	int "Trickle Imin (ms)"
	default 4000
	range 100 60000
	help
	  Minimum Trickle interval in milliseconds. Matches spec Imin=4s=4000 ms
	  (draft-lichen-rpl-lora-00.md:235, RFC 6206). Smaller values speed up
	  convergence but increase traffic.

config LICHEN_RPL_TRICKLE_IMAX_DOUBLINGS
	int "Trickle Imax doublings"
	default 8
	range 1 16
	help
	  Number of times Imin is doubled to reach Imax (RFC 6206).
	  Imax = Imin * 2^doublings.

config LICHEN_RPL_TRICKLE_K
	int "Trickle redundancy constant"
	default 10
	range 1 255
	help
	  Redundancy constant k for Trickle (RFC 6206).
	  Suppress transmission if k or more consistent messages heard.

config LICHEN_RPL_MIN_HOP_RANK_INCREASE
	int "MinHopRankIncrease"
	default 256
	range 1 65535
	help
	  Minimum increase in rank between a node and its parent.
	  Standard value is 256 (RFC 6550).

config LICHEN_RPL_MAX_RANK_INCREASE
	int "MaxRankIncrease"
	default 2048
	range 256 65535
	help
	  Maximum allowed increase from the lowest rank ever held.
	  Prevents routing loops during topology changes.

config LICHEN_RPL_PARENT_SWITCH_THRESHOLD
	int "Parent switch threshold"
	default 192
	range 0 65535
	depends on LICHEN_RPL_MRHOF
	help
	  Minimum cost improvement required to switch parents.
	  Provides hysteresis to prevent flapping.

config LICHEN_RPL_LOG_LEVEL
	int "RPL log level"
	default 3
	range 0 4
	help
	  Log level for LICHEN RPL:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_CCP_TDMA
	bool "CCP-1 TDMA time slots with RPL"
	default y
	depends on LICHEN_RPL
	select LICHEN_TDMA
	select LICHEN_CCP_TIME_SYNC
	help
	  Enable TDMA integration for CCP-1 (coordinated capacity planning).
	  Adds support for slot assignment, beacon sync, and tdma_tx_allowed()
	  checks coordinated with RPL DODAG and DIO options per
	  spec/02a-coordinated-capacity.md §2a.2, §2a.5 (FSM, desync recovery)
	  and ccp16.json, ccp_tdma.json. See AGENTS.md init graph.
	  Must follow lichen_link_init() before tdma_init().

config LICHEN_CHANNEL_AGILITY
	bool "Channel agility / rendezvous (CCP-1/12)"
	default y
	depends on LICHEN_RPL
	select LICHEN_MULTI_CHANNEL_ENABLED
	help
	  Enable frequency/channel agility and rendezvous per CCP-1. Uses
	  control channel CH0 for RPL traffic, hash-based selection for data
	  channels, synchronized via SFN from RPL beacons/DIOs.

config LICHEN_ADAPTIVE_SF
	bool "Adaptive spreading factor (CCP-16)"
	default y
	depends on LICHEN_RPL
	select LICHEN_ADAPTIVE_SF_ENABLED
	help
	  Enable adaptive SF selection using per-neighbor SNR EMA and density
	  from RPL metrics (CCP-16). Integrates with LICHEN_LINK_CCP16_LOAD_BALANCING.

endif # LICHEN_RPL
