# LICHEN protocol subsystem Kconfig

menuconfig LICHEN
	bool "LICHEN protocol stack"
	help
	  Enable the LICHEN (LoRa IPv6 CoAP Hybrid Extended Network)
	  protocol stack for mesh networking over LoRa.

if LICHEN

rsource "app_identity/Kconfig"
rsource "app_interface/Kconfig"
rsource "coap/Kconfig"
rsource "crypto/Kconfig"
rsource "edhoc/Kconfig"
rsource "hal/Kconfig"
rsource "link/Kconfig"
rsource "meshcore/Kconfig"
rsource "meshtastic/Kconfig"
rsource "l2/Kconfig"
rsource "oscore/Kconfig"
rsource "schc/Kconfig"
rsource "senml/Kconfig"
rsource "rpl/Kconfig"
rsource "routing/Kconfig"
rsource "transport/Kconfig"

config LICHEN_INSECURE_DEBUG
	bool "INSECURE: enable dev/test stubs with insecure key handling"
	default n
	help
	  DANGER: Master opt-in for development/test stub code paths that
	  handle key material insecurely (stub key derivation that reuses
	  or weakens keys, fixed publicly-known dev keys). Builds with
	  this option enabled provide NO real cryptographic security and
	  log loud warnings about insecure keys at runtime.

	  This option exists ONLY for host-based unit tests and bench
	  development builds. Never enable it in production firmware:
	  doing so may expose key material and allows anyone to forge
	  frames.

config LICHEN_ADAPTIVE_SF_ENABLED
	bool "Adaptive spreading factor selection (per-neighbor SNR/CCP16)"
	default y
	depends on LICHEN_RPL
	help
	  Enable dynamic selection of LoRa spreading factor per neighbor based on
	  SNR measurements and density signals from CCP16. Improves network
	  capacity in dense deployments. See spec/appendix-design-rationale.md.
	  When disabled, falls back to
	  CONFIG_LICHEN_DEFAULT_SF.

config LICHEN_DEFAULT_SF
	int "Default spreading factor (when adaptive SF disabled)"
	default 10
	range 7 12
	depends on LICHEN
	help
	  Default SF for transmissions when adaptive SF is not enabled.
	  SF7 = highest bitrate/shortest range; SF12 = lowest bitrate/longest range.
	  Must match regional regulations and link budget.

config LICHEN_DUTY_CYCLE
	bool "Duty cycle tracker (CCP-13)"
	default y
	depends on LICHEN

endif # LICHEN

