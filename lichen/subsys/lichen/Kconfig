# LICHEN protocol subsystem Kconfig

menuconfig LICHEN
	bool "LICHEN protocol stack"
	help
	  Enable the LICHEN (LoRa IPv6 CoAP Hybrid Extended Network)
	  protocol stack for mesh networking over LoRa.

if LICHEN

rsource "app_identity/Kconfig"
rsource "app_interface/Kconfig"
rsource "coap/Kconfig"
rsource "crypto/Kconfig"
rsource "edhoc/Kconfig"
rsource "hal/Kconfig"
rsource "link/Kconfig"
rsource "meshcore/Kconfig"
rsource "meshtastic/Kconfig"
rsource "l2/Kconfig"
rsource "oscore/Kconfig"
rsource "schc/Kconfig"
rsource "senml/Kconfig"
rsource "rpl/Kconfig"
 rsource "routing/Kconfig"
 rsource "transport/Kconfig"

config LICHEN_ADAPTIVE_SF_ENABLED
	bool "Adaptive spreading factor per-neighbor (project-LICHEN-zrh2.2)"
	depends on LICHEN
	default y
	help
	  Enable per-neighbor SF tracking, SNR EWMA, upgrade/downgrade hysteresis
	  for dynamic TX SF selection. Adds fields to gradient entries. See
	  project-LICHEN-zrh2.2 and spec section 2a. SF10 is normative baseline.

config LICHEN_DEFAULT_SF
	int "Default spreading factor"
	depends on LICHEN
	default 10
	range 7 12
	help
	  Default SF7-SF12 for transmissions when adaptive SF disabled or no
	  per-neighbor data available. SF10 is the normative baseline per
	  coordinated-capacity spec.

config LICHEN_DUTY_CYCLE
	bool "Duty cycle tracker (CCP-13)"
	default y
	depends on LICHEN

endif # LICHEN


