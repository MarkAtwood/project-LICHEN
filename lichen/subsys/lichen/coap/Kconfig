# LICHEN CoAP subsystem Kconfig

menuconfig LICHEN_COAP
	bool "LICHEN CoAP support"
	depends on LICHEN
	select COAP
	help
	  Enable LICHEN CoAP support (client and/or server).

if LICHEN_COAP

config LICHEN_COAP_CLIENT
	bool "LICHEN CoAP client"
	select COAP_CLIENT
	default y
	help
	  Enable LICHEN CoAP client for making requests to mesh nodes.

config LICHEN_COAP_CLIENT_LOG_LEVEL
	int "CoAP client log level"
	depends on LICHEN_COAP_CLIENT
	default 3
	range 0 4
	help
	  Log level for LICHEN CoAP client:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_COAP_CLIENT_OSCORE
	bool "OSCORE protection for CoAP client"
	depends on LICHEN_COAP_CLIENT
	depends on LICHEN_OSCORE
	default y
	help
	  Enable OSCORE (RFC 8613) end-to-end security for CoAP requests.
	  When enabled, requests with a non-NULL oscore_ctx are protected
	  using AES-CCM-16-64-128. Responses are automatically decrypted
	  before delivery to the callback.

	  SECURITY: Per spec/06-security.md Section 8.7, OSCORE is
	  recommended for all CoAP traffic to provide end-to-end security
	  independent of the link layer.

config LICHEN_COAP_SERVER
	bool "LICHEN CoAP server"
	select COAP_SERVER
	default y
	help
	  Enable LICHEN CoAP server for responding to requests from mesh nodes.
	  Exposes LCI resources: /status, /config, /neighbors, /keys, /msg/inbox,
	  and /.well-known/core for resource discovery.

config LICHEN_COAP_SERVER_STANDALONE
	bool "Standalone subsystem-owned CoAP service (coap_server.c)"
	depends on LICHEN_COAP_SERVER
	depends on !LICHEN_COAP_CONFIG
	default n
	help
	  Compile the subsystem-owned COAP_SERVICE (lichen_coap_server) from
	  coap_server.c, which registers its own /status, /config, /neighbors,
	  /msg/inbox resources. The /keys resource is provided by the
	  LICHEN_COAP_KEYS module (coap_keys.c).

	  Keep this off in applications that define their own CoAP service
	  and use the per-resource handler modules (LICHEN_COAP_STATUS,
	  LICHEN_COAP_CONFIG, LICHEN_COAP_KEYS, LICHEN_COAP_MSG) — the
	  gateway app does this with its lichen_coap service — otherwise the
	  same LCI paths are served twice on different sockets.

config LICHEN_COAP_SERVER_LOG_LEVEL
	int "CoAP server log level"
	depends on LICHEN_COAP_SERVER
	default 3
	range 0 4
	help
	  Log level for LICHEN CoAP server:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_COAP_SERVER_OSCORE
	bool "OSCORE protection for CoAP server"
	depends on LICHEN_COAP_SERVER
	depends on LICHEN_OSCORE
	default y
	help
	  Enable OSCORE (RFC 8613) end-to-end security for CoAP server.
	  When enabled, the server can verify OSCORE-protected requests
	  and send OSCORE-protected responses.

	  SECURITY: Per spec/06-security.md Section 8.7, OSCORE is
	  recommended for all CoAP traffic to provide end-to-end security
	  independent of the link layer.

config LICHEN_COAP_CONFIG
	bool "LCI /config resource handlers"
	depends on LICHEN_COAP_SERVER
	imply ZCBOR
	select LICHEN_COAP_KEYS
	help
	  Enable CoAP server resources for node configuration per LCI spec
	  section 17.5.2:
	  - GET/PUT /config - node name and role
	  - GET/PUT /config/radio - radio parameters
	  - GET /config/identity - read-only identity info

	  Requires a configuration provider to be registered via
	  lichen_coap_config_register() before handling requests.

config LICHEN_COAP_CONFIG_LOG_LEVEL
	int "CoAP config log level"
	depends on LICHEN_COAP_CONFIG
	default 3
	range 0 4
	help
	  Log level for LICHEN CoAP config handlers:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_COAP_STATUS
	bool "LCI /status resource handlers"
	depends on LICHEN_COAP_SERVER
	default y
	help
	  Enable LCI /status resource handlers per spec section 17.5.3.
	  Implements:
	  - GET /status - Node status with DODAG, time, radio stats
	  - GET /status/neighbors - Neighbor table with RSSI/SNR/ETX
	  - GET /status/routes - Routing table

	  All resources support RFC 7641 Observe for push notifications.

config LICHEN_COAP_STATUS_MAX_NEIGHBORS
	int "Maximum neighbors in /status/neighbors response"
	depends on LICHEN_COAP_STATUS
	default 8
	range 1 32
	help
	  Maximum number of neighbor entries returned in a single
	  /status/neighbors response.

config LICHEN_COAP_STATUS_MAX_ROUTES
	int "Maximum routes in /status/routes response"
	depends on LICHEN_COAP_STATUS
	default 8
	range 1 32
	help
	  Maximum number of route entries returned in a single
	  /status/routes response.

config LICHEN_COAP_STATUS_LOG_LEVEL
	int "CoAP status log level"
	depends on LICHEN_COAP_STATUS
	default 3
	range 0 4
	help
	  Log level for LICHEN CoAP status handlers:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_COAP_MSG
	bool "LCI /msg/* resource handlers"
	depends on LICHEN_COAP_SERVER
	select LICHEN_COAP_STATUS
	imply ZCBOR
	select COAP_URI_WILDCARD
	help
	  Enable CoAP server resources for application-level messaging per
	  LCI spec section 17.5.7:
	  - POST /msg/sent - queue outbound message
	  - GET /msg/sent/<id> - get sent message status
	  - GET /msg/inbox - retrieve inbound messages (Observable)
	  - POST /msg/ack - acknowledge message receipt

	  Messages are queued in memory with configurable limits. This is
	  an optional feature for chat-like human messaging; applications
	  may instead use CoAP directly to mesh nodes.

config LICHEN_COAP_MSG_LOG_LEVEL
	int "CoAP msg log level"
	depends on LICHEN_COAP_MSG
	default 3
	range 0 4
	help
	  Log level for LICHEN CoAP messaging handlers:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_COAP_KEYS
	bool "LCI /keys resource handlers"
	depends on LICHEN_COAP_SERVER
	# coap_keys.c calls slip_transport_iface_get() and includes
	# <lichen/transport/slip_transport.h> to scope admin (PUT/DELETE)
	# access to the SLIP LCI interface. Without the SLIP transport the
	# header is off the include path and the symbol is undefined at link,
	# so this option genuinely requires it (bd a2a2).
	depends on LICHEN_SLIP_TRANSPORT
	depends on ZCBOR
	select COAP_URI_WILDCARD
	imply ZCBOR
	imply TINYCRYPT_SHA256
	help
	  Enable CoAP server resources for key store management per LCI spec
	  section 17.5.5:
	  - GET /keys - list peer IIDs with pubkey fingerprints, trust level
	  - GET /keys/{iid} - get specific peer's full pubkey
	  - PUT /keys/{iid} - add/update peer key (requires local admin)
	  - DELETE /keys/{iid} - remove peer (requires local admin)

	  Keys are stored in memory. TOFU key pinning is enforced: once a key
	  is learned for an IID, it cannot be changed without explicit removal.

	  SECURITY: Write operations require local admin access (loopback or
	  BLE LCI interface).

config LICHEN_COAP_KEYS_MAX_ENTRIES
	int "Maximum key store entries"
	depends on LICHEN_COAP_KEYS
	default 16
	range 4 16
	help
	  Maximum number of peer keys to store. Capped at 16 by CBOR encoder
	  stack usage in encode_keys_list_cbor() and the BUILD_ASSERT in
	  coap_keys.c. Each entry requires ~60 bytes of RAM.

config LICHEN_COAP_KEYS_LOG_LEVEL
	int "CoAP keys log level"
	depends on LICHEN_COAP_KEYS
	default 3
	range 0 4
	help
	  Log level for LICHEN CoAP keys handlers:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_COAP_KEYS_TEST_HOOKS
	bool "Test hooks for key store"
	depends on LICHEN_COAP_KEYS
	depends on ZTEST
	help
	  Enable test hooks for resetting the key store. Only for testing.

config LICHEN_COAP_LOCATION
	bool "CoAP /sensors/location resource (SenML position)"
	depends on !LICHEN_COAP_SERVER_STANDALONE
	depends on LICHEN_SENML
	depends on LICHEN_HAL
	depends on LICHEN_LORA_L2
	default n
	help
	  Serve GET /sensors/location as a SenML pack (application/senml+cbor,
	  spec 12-apps.md section 18.2.2) describing the node's current position,
	  or 4.04 when it has no valid fix. Requires the SenML encoder, the HAL
	  location provider, and the LoRa L2 (for the node EUI-64 base name).

config LICHEN_COAP_LOCATION_LOG_LEVEL
	int "CoAP location log level"
	depends on LICHEN_COAP_LOCATION
	default 3
	range 0 4
	help
	  Log level for the LICHEN CoAP location handler:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_COAP_DEADDROP
	bool "LCI /deaddrop DTN store-forward resource"
	depends on LICHEN_COAP_SERVER
	depends on LICHEN_OSCORE
	depends on LICHEN_DTN
	select COAP_URI_WILDCARD
	imply ZCBOR
	help
	  LCI /deaddrop (POST to store encrypted msg for recipient, GET?node=IID to pickup pending)
	  and /confessions for anonymous rate-limited broadcast. Per spec 18.11 and 18.9,
	  uses OSCORE E2E (after oscore_init() + lichen_coap_client_init() per AGENTS.md),
	  SenML+CBOR (112), DTN storage, query param support via URI wildcard.

config LICHEN_COAP_DEADDROP_RATE_LIMIT_MS
	int "Rate limit for deaddrop/confessions POSTs in ms"
	depends on LICHEN_COAP_DEADDROP
	default 60000
	range 1000 600000
	help
	  Minimum interval between POSTs per-source (IID bucket) for /deaddrop and
	  /confessions. Prevents spam/DoS and storage exhaustion (spec 12-apps.md:18.9,
	  06-security.md). 60s default balances utility vs abuse prevention.

config LICHEN_COAP_DEADDROP_MAX_STORAGE
	int "Max deaddrop storage entries"
	depends on LICHEN_COAP_DEADDROP
	default LICHEN_DTN_MAX_MESSAGES
	range 1 64
	help
	  Maximum messages in DTN deaddrop buffer.

config LICHEN_COAP_DEADDROP_LOG_LEVEL
	int "CoAP deaddrop log level"
	depends on LICHEN_COAP_DEADDROP
	default 3
	range 0 4
	help
	  Log level for LICHEN CoAP deaddrop handler: 0=off, 1=error, 2=warning, 3=info, 4=debug

endif # LICHEN_COAP
