# LICHEN link layer Kconfig

menuconfig LICHEN_LINK
	bool "LICHEN link layer"
	depends on LICHEN
	select CRC
	select LICHEN_CRYPTO_AES_CCM
	select LICHEN_SCHC
	select TINYCRYPT
	select TINYCRYPT_SHA256
	help
	  Enable the LICHEN link layer with Schnorr-48 signatures
	  and replay protection. Automatically enables SCHC header
	  compression for IPv6 packet handling.

if LICHEN_LINK

config LICHEN_LINK_SCHNORR
	bool "Schnorr-48 link signatures"
	default y
	select LICHEN_CRYPTO_MONOCYPHER
	help
	  Enable 48-byte Schnorr signatures per draft-lichen-schnorr-00.
	  This provides sender authentication for every link-layer frame.

config LICHEN_LINK_MAX_NEIGHBORS
	int "Maximum tracked neighbors"
	default 16
	range 4 64
	help
	  Maximum number of neighbors to track replay state for.
	  Each neighbor uses approximately 20 bytes of RAM (EUI-64 +
	  64-bit replay window + metadata).

config LICHEN_LINK_LOG_LEVEL
	int "Link layer log level"
	default 3
	range 0 4
	help
	  Log level for LICHEN link layer:
	  0=off, 1=error, 2=warning, 3=info, 4=debug

config LICHEN_LINK_MIC_SKIP_VERIFY
	bool "Skip MIC verification (DANGEROUS)"
	default n
	help
	  DANGER: Disables MIC verification, allowing forged frames to be
	  accepted. This option exists ONLY for testing environments where
	  link-layer keys are not yet provisioned.

	  NEVER enable this in production — it completely disables frame
	  authentication and allows any attacker to inject packets.

	  When enabled, a warning is logged for every received frame to
	  make the insecure state obvious.

config LICHEN_LINK_INSECURE_CRC32_MIC
	bool "Allow CRC32 MIC fallback (INSECURE)"
	default n
	help
	  DANGER: Allows CRC32 to be used as the MIC when no link key is
	  configured. CRC32 provides error detection ONLY — it provides NO
	  cryptographic authentication. Any attacker can compute valid CRC32
	  values and forge frames.

	  This option exists ONLY for:
	  - Development and testing
	  - Networks with higher-layer authentication (e.g., OSCORE)

	  For production deployments requiring link-layer security, configure
	  a link key to enable AES-CCM-64 MIC instead of enabling this option.

	  When enabled, a compile-time warning is emitted to ensure the
	  insecure configuration is visible in build logs.

config LICHEN_LINK_EPOCH_PERSIST
	bool "Persist the link TX epoch across reboots"
	depends on SETTINGS
	help
	  Persist the link-layer TX epoch to the settings subsystem and
	  advance it by one on every boot. This keeps a rebooted node's
	  (epoch, seqnum) counter monotonically ahead of what its peers
	  remember in their replay windows, so frames sent after a reboot
	  are not rejected as replays.

	  Without this, link_ctx picks a random epoch in [128,255] at boot,
	  which is lower than the peer's remembered epoch ~50% of the time
	  and causes one-way replay deafness until both nodes reset together
	  (lora_ipv6_mesh-3uhb). Costs one small settings write per boot.

config LICHEN_LINK_EPOCH_TEST_HOOKS
	bool "Test hooks for epoch persistence"
	depends on LICHEN_LINK_EPOCH_PERSIST
	depends on ZTEST
	help
	  Expose lichen_link_epoch_test_reset() to clear the in-RAM
	  boot-epoch cache so tests can simulate a reboot and exercise the
	  persist-and-advance behavior. Testing only.

config LICHEN_LINK_CCP16_LOAD_BALANCING
	bool "CCP16 density-aware load balancing"
	depends on LICHEN_RPL
	depends on LICHEN_LINK_EPOCH_PERSIST
	select LICHEN_SCHC
	help
	  Enable CCP-16 coordinated load balancing for high-density
	  (DEFCON-scale) deployments. References density tracking, adaptive
	  SF thresholds, and channel utilization from
	  spec/appendix-design-rationale.md. Explicitly selects SCHC and
	  link epoch features required for TDMA/multi-channel operation.

config LICHEN_TDMA
	bool "TDMA slot scheduling / gateway-centric mode (beacon-sync, slot assign, spatial reuse)"
	depends on LICHEN_LINK_CCP16_LOAD_BALANCING
	depends on LICHEN_RPL
	select LICHEN_SCHC
	help
	  Enable TDMA struct and lichen_tdma_init() after lichen_link_load_key() per
	  AGENTS.md init graph and spec/02a-coordinated-capacity.md §2a.2 (guard=100ms,
	  slot=hash(EUI64^epoch)%num_slots via lichen_hash_32; validated by ccp16.json
	  + ccp_tdma.json). Supports beacon sync, GPS sync, dynamic slot assignment
	  from root, spatial reuse, desync FSM per §2a.5. Must not call before key
	  loaded. Mimics lichen_link_ctx pattern exactly.

config LICHEN_CCP_TIME_SYNC
	bool "CCP time synchronization (SFN, beacons, GPS stratum)"
	default y
	depends on LICHEN_LINK_CCP16_LOAD_BALANCING
	help
	  Enable time sync for CCP-16 desync recovery, TDMA slots, and RPL
	  version interactions per spec/02a-coordinated-capacity.md §2a.4, §2a.5.
	  Uses beacon SFN with GPS stratum-0 priority, local RTC fallback. Matches
	  ccp16.json, ccp16-desync.json vectors exactly. SECURITY: signed beacons only.

config LICHEN_TDMA_BEACON_SYNC
	bool "Beacon-based TDMA synchronization"
	depends on LICHEN_TDMA
	default y
	help
	  Nodes sync time and slots from gateway periodic beacons.

config LICHEN_MULTI_CHANNEL_ENABLED
	bool "Multi-channel TX/RX coordination (CCP-9/12)"
	depends on LICHEN_LINK
	default y
	help
	  Enable multi-channel operation. Control on CH0,
	  data channels 1-N with hash/rendezvous selection, idle listen on control,
	  dynamic hop for RX. Requires updated radio API and link scheduler.

config LICHEN_N_CHANNELS
	int "Number of LoRa channels (incl. control)"
	depends on LICHEN_MULTI_CHANNEL_ENABLED
	default 8
	range 1 16
	help
	  Matches regional plan (e.g. 8 for EU868). Used for mod N in
	  select_channel/hash_32 and synchronized_hop_channel(CCP-12).

endif # LICHEN_LINK
