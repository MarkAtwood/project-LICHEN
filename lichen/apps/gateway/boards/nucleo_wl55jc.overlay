/*
 * Nucleo-WL55JC — STM32WL55 with built-in sub-GHz radio
 *
 * The STM32WL55 integrates an SX126x-compatible sub-GHz transceiver
 * reachable via the internal SUBGHZSPI peripheral.  The Zephyr board
 * definition exposes it as &subghzspi / the STM32 sub-GHz radio node.
 *
 * References:
 *   boards/arm/nucleo_wl55jc/nucleo_wl55jc.dts
 *   drivers/lora/sx126x.c (subghz variant)
 */

/*
 * &lora is the sub-GHz radio node defined in nucleo_wl55jc.dts.
 * Already enabled by default; nothing to override for basic use.
 * Frequency and power are configured at runtime via LoRa API.
 */
/ {
	chosen {
		zephyr,lora      = &lora;
		zephyr,uart-pipe = &lpuart1;
	};
};
