/*
 * native_sim overlay for the LICHEN gateway.
 *
 * Instantiates the loopback LoRa driver for testing without hardware.
 * For full simulation with multiple nodes, switch to "lichen,lora-sim"
 * and update native_sim.conf accordingly.
 */

/ {
	aliases {
		lora0 = &lora_sim;
	};

	chosen {
		zephyr,lora = &lora_sim;
	};

	lora_sim: lora {
		compatible = "lichen,lora-loopback";
		status = "okay";
	};
};
