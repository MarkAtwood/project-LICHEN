menu "LICHEN Gateway"

config LORA_LICHEN_BLE
	bool "BLE UART interface (Nordic UART Service)"
	depends on BT
	depends on BT_PERIPHERAL
	default n
	help
	  Enable the Nordic UART Service (NUS) GATT profile so a phone can
	  exchange SLIP-framed IPv6 packets with the gateway over BLE UART.
	  Gate per board: the nucleo_wl55jc has no BLE radio; enable on
	  nRF52840-based boards instead.

config LORA_LICHEN_GATEWAY_RPL_ROOT
	bool "RPL root signalling"
	depends on LICHEN_RPL
	depends on BROKEN
	default n
	help
	  Enable gateway DIO/DAO processing and root signalling.

	  This is intentionally unavailable until the gateway has an app-level
	  packet I/O integration that drives the caller-owned LICHEN RPL state
	  machine. With this option disabled, the gateway advertises itself as
	  non-RPL-capable in /status so users do not mistake it for a complete
	  mesh root.

endmenu

source "Kconfig.zephyr"
