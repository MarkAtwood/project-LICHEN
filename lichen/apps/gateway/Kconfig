menu "LICHEN Gateway"

config LICHEN_MESHTASTIC_GATEWAY_ADAPTER_TEST_SURFACE
	bool "Expose Meshtastic gateway adapter surface for ztests"
	depends on ZTEST
	default n
	help
	  Internal ztest hook that exposes Meshtastic gateway adapter CoAP
	  resources without enabling the production BLE GATT backend.

config LICHEN_INBOUND_LOCATION_TEST_SURFACE
	bool "Expose inbound local-client location resource for ztests"
	depends on ZTEST
	default n
	help
	  Internal ztest hook that exposes the local-client location POST
	  resource without enabling a production local-client write transport.

config LICHEN_GATEWAY_ANNOUNCE_NETWORK_LOCATION_FALLBACK
	bool "Publish announce-derived coordinates as approximate NETWORK location"
	default n
	help
	  Allow verified LICHEN announce coordinate metadata from another peer to
	  update the gateway's local NETWORK location as an approximate
	  mesh-derived fallback. Leave disabled unless the gateway profile
	  intentionally wants peer announce coordinates to stand in for local
	  position. Disabled builds still parse and retain announce coordinates
	  for routing/diagnostics, but do not publish them as this node location.

config LORA_LICHEN_BLE
	bool "Native BLE LCI interface"
	depends on BT
	depends on BT_PERIPHERAL
	depends on BT_MAX_CONN = 1
	select LICHEN_APP_INTERFACE
	select NET_L2_DUMMY
	default n
	help
	  Enable the native LICHEN BLE Local Client Interface so a phone can
	  exchange SLIP-framed IPv6 packets with the gateway over BLE GATT.
	  By default this uses LICHEN-specific service and characteristic UUIDs.
	  Gate per board: enable only on targets with an enabled Zephyr BLE HCI
	  device. Keep the HAL BLE-local capability disabled until the board has a
	  validated bidirectional local-client transport.

config LORA_LICHEN_BLE_LEGACY_NUS
	bool "Use legacy Nordic UART Service UUIDs for native BLE LCI"
	depends on LORA_LICHEN_BLE
	default n
	help
	  Keep the native LICHEN BLE LCI surface on the Nordic UART Service UUID
	  triplet for existing mutually exclusive native product images. Do not
	  enable this in images that also need MeshCore compatibility: MeshCore
	  owns NUS UUIDs with raw MeshCore frame semantics.

config NET_IF_MAX_IPV6_COUNT
	default 2 if LORA_LICHEN_BLE

config LORA_LICHEN_MESHTASTIC_BLE
	bool "Meshtastic-compatible BLE GATT interface"
	depends on BT
	depends on BT_PERIPHERAL
	depends on BT_MAX_CONN = 1
	depends on LICHEN_MESHTASTIC_CODEC
	depends on LICHEN_LINK
	depends on !LORA_LICHEN_BLE
	select LICHEN_APP_IDENTITY
	select LICHEN_APP_INTERFACE
	select LICHEN_MESHTASTIC_ADAPTER
	default n
	help
	  Enable the Meshtastic BLE service UUID and raw protobuf
	  ToRadio/FromRadio/FromNum characteristics. This is a local app
	  compatibility surface only; it does not make LICHEN RF packets
	  Meshtastic-compatible. The first implementation owns a single
	  Meshtastic app session and therefore requires CONFIG_BT_MAX_CONN=1.
	  App identity is selected so NodeDB sync can enumerate known LICHEN
	  peers through the common app-visible identity table.

config LORA_LICHEN_MESHCORE_BLE
	bool "MeshCore-compatible BLE GATT interface"
	depends on BT
	depends on BT_PERIPHERAL
	depends on BT_MAX_CONN = 1
	depends on BT_SMP || ZTEST
	depends on BT_FIXED_PASSKEY || ZTEST
	depends on LICHEN_MESHCORE_CODEC
	depends on LICHEN_LINK
	depends on !LORA_LICHEN_BLE
	depends on !LORA_LICHEN_MESHTASTIC_BLE
	select LICHEN_APP_IDENTITY
	select LICHEN_APP_INTERFACE
	select LICHEN_MESHCORE_ADAPTER
	select BT_SMP_ENFORCE_MITM if !ZTEST
	default n
	help
	  Enable the MeshCore-compatible Nordic UART Service UUIDs with raw
	  MeshCore command/response frames. This is a local app compatibility
	  surface only; it does not make LICHEN RF packets MeshCore-compatible.
	  The first implementation owns a single MeshCore app session, requires
	  CONFIG_BT_MAX_CONN=1, CONFIG_BT_SMP, and CONFIG_BT_FIXED_PASSKEY. It
	  uses authenticated encrypted GATT access in production builds. Plain
	  permissions are limited to ztest/native_sim test builds.

config LORA_LICHEN_MESHCORE_BLE_QUEUE_DEPTH
	int "MeshCore BLE frame queue depth"
	depends on LORA_LICHEN_MESHCORE_BLE
	default 4
	range 1 16
	help
	  Number of complete raw MeshCore frames retained for app RX and TX.

config LORA_LICHEN_MESHCORE_BLE_NAME
	string "MeshCore BLE advertised name"
	depends on LORA_LICHEN_MESHCORE_BLE
	default "MeshCore-LICHEN"
	help
	  Short advertised name used only in MeshCore compatibility mode. Keep
	  the default MeshCore- prefix unless real-client smoke tests prove
	  another prefix is discoverable.

config LORA_LICHEN_MESHCORE_BLE_PASSKEY
	int "MeshCore BLE fixed pairing passkey"
	depends on LORA_LICHEN_MESHCORE_BLE
	default 123456
	range 0 999999
	help
	  Six-digit MeshCore compatibility passkey installed with
	  bt_passkey_set() before advertising starts. This is the first
	  product-mode hook for authenticated local pairing; production boards
	  should override it from provisioning or persistent settings once the
	  MeshCore config-secret policy is implemented.

config LORA_LICHEN_MESHCORE_COMPAT_SETTINGS_PERSISTENCE
	bool "Persist MeshCore compatibility-local settings"
	depends on LORA_LICHEN_MESHCORE_BLE || ZTEST
	depends on LICHEN_MESHCORE_ADAPTER
	depends on SETTINGS_NVS
	default n
	help
	  Persist only MeshCore app-compatibility local state through Zephyr
	  settings/NVS: display name, channel 0 compatibility record, auto-add
	  config, default flood scope, and MeshCore BLE PIN. This store is
	  intentionally separate from native LICHEN identity, OSCORE/link keys,
	  group/routing state, and radio configuration.

config LORA_LICHEN_MESHTASTIC_BLE_QUEUE_DEPTH
	int "Meshtastic BLE FromRadio queue depth"
	depends on LORA_LICHEN_MESHTASTIC_BLE
	default 20
	range LORA_LICHEN_MESHTASTIC_BLE_QUEUE_DEPTH_MIN 32
	help
	  Number of complete FromRadio protobuf values retained for app reads.
	  Keep enough headroom for a queued heartbeat plus a full configuration
	  sync burst with the default bounded NodeDB peer cap.

config LORA_LICHEN_MESHTASTIC_BLE_QUEUE_DEPTH_MIN
	int
	default 20

config LORA_LICHEN_MESHTASTIC_BLE_TO_RADIO_QUEUE_DEPTH
	int "Meshtastic BLE ToRadio queue depth"
	depends on LORA_LICHEN_MESHTASTIC_BLE
	default 8
	range 1 16
	help
	  Number of complete ToRadio protobuf values retained for gateway
	  processing after app writes.

config LORA_LICHEN_GATEWAY_MESSAGE_QUEUE_DEPTH
	int "Gateway local message ingress queue depth"
	depends on LORA_LICHEN_MESHTASTIC_BLE || LORA_LICHEN_MESHCORE_BLE || \
		   LICHEN_MESHTASTIC_GATEWAY_ADAPTER_TEST_SURFACE
	default 4
	range 1 16
	help
	  Number of app-ingress text messages accepted from compatibility
	  surfaces and retained for the normal LICHEN message sender. Until that
	  sender is enabled, this bounded queue is the deterministic local
	  contract and does not transmit on BLE or LoRa by itself.

config LORA_LICHEN_GATEWAY_RPL_ROOT
	bool "RPL root signalling"
	depends on LICHEN_RPL
	default y
	help
	  Enable gateway as RPL DODAG root (lichen_rpl_dodag_init_root).
	  Initializes per AGENTS.md order after link_ctx. Drives Trickle DIOs
	  as root for mesh formation. Updates /status to reflect joined root role.

config LICHEN_GATEWAY_RX1_DELAY_MS
	int "RX1-style delay before answering a CoAP request (ms)"
	default 0
	help
	  Milliseconds to wait after receiving a CoAP request before sending
	  the response, giving a half-duplex requesting node time to switch
	  its radio from TX (the request it just sent) to RX. Without it, the
	  reply can arrive during the requester's TX->RX turnaround and be
	  missed (lora_ipv6_mesh-fe1z, observed on the T1000-E/LR1110). 0
	  disables the delay. ~100 ms is a safe LoRa value.

config LICHEN_GATEWAY_PREFIX_DELEGATION
	bool "Enable IPv6 prefix delegation from WiFi/Ethernet backhaul to RPL mesh"
	depends on LICHEN_RPL
	depends on NET_DHCPV6
	depends on NET_IPV6_ND
	select NET_MGMT
	select NET_MGMT_EVENT
	select NET_MGMT_EVENT_INFO
	select WIFI
	select NET_L2_WIFI_MGMT
	select NET_IPV6_ND6
	imply NET_DHCPV6_CLIENT
	default n
	help
	  IPv6 prefix delegation from WiFi STA backhaul (RA via net_mgmt) to RPL DODAG root for 6LBR.
	  Selected by LICHEN_GATEWAY_WIFI_STATION. Requires wifi_mgmt_event_handler in main.c for
	  NET_EVENT_WIFI_CONNECT_RESULT/NET_EVENT_IPV6_PREFIX_ADD per AGENTS.md init order and
	  spec/appendix-border-router.md. Tune heaps in board .conf (see previous beads).

config LICHEN_GATEWAY_WIFI_SSID
	string "WiFi SSID for backhaul"
	default "lichen-test"
	depends on LICHEN_GATEWAY_PREFIX_DELEGATION
	help
	  SSID for WiFi station mode (used by wifi_mgmt in main.c).

config LICHEN_GATEWAY_WIFI_PSK
	string "WiFi PSK for backhaul"
	default "lichen123"
	depends on LICHEN_GATEWAY_PREFIX_DELEGATION
	help
	  Pre-shared key for WiFi STA. INSECURE default for bench; override per deployment via CoAP /config.

config LICHEN_GATEWAY_COORDINATION
	bool "Gateway coordination protocol (TDMA slots, node registry, handoff)"
	depends on LICHEN_RPL
	depends on LICHEN_COAP
	depends on LICHEN_COAP_SERVER || LICHEN_COAP_CONFIG
	default n
	help
	  Enable multi-gateway coordination per mugl.3 / spec/08-gateway-coordination.md
	  and spec/02a-coordinated-capacity.md §2a.2 (TDMA slot coordination across
	  gateways). Backbone UDP/CoAP. Supports closed (PSK+OSCORE) and open
	  (Ed25519+TOFU) modes. Required for multi-BR deployments.

choice LICHEN_GW_FEDERATION_MODE
	prompt "Gateway federation mode for coordination"
	default LICHEN_GW_FEDERATION_CLOSED
	depends on LICHEN_GATEWAY_COORDINATION
	help
	  Closed: PSK-based for single-operator. Open: signature-based for
	  multi-operator with TOFU. Dual supports both simultaneously (mugl.3).

config LICHEN_GW_FEDERATION_CLOSED
	bool "Closed federation (PSK + OSCORE)"

config LICHEN_GW_FEDERATION_OPEN
	bool "Open federation (Ed25519 + TOFU)"

config LICHEN_GW_FEDERATION_DUAL
	bool "Dual federation (both modes)"

endchoice

config LICHEN_GW_PSK
	string "Base64-encoded PSK for closed/dual federation"
	depends on LICHEN_GATEWAY_COORDINATION
	depends on LICHEN_GW_FEDERATION_CLOSED || LICHEN_GW_FEDERATION_DUAL
	help
	  Shared secret for OSCORE in closed federation. Must match on all
	  cooperating gateways in closed mode. 32+ bytes recommended.

# Force modular CoAP (lichen_coap service + LICHEN_COAP_CONFIG) for
# gateway; legacy standalone server (lichen_coap_server) would duplicate
# lichen_config ownership and lacks linker bounds on nucleo_wl55jc/r1_neo.
config LICHEN_COAP_SERVER_STANDALONE
	default n

config LICHEN_GATEWAY_WIFI_STATION
	bool "WiFi station backhaul"
	default y if BOARD_HELTEC_WIFI_LORA32_V3_ESP32S3_PROCPU
	select WIFI
	select WIFI_NM
	select ESP_WIFI_ENABLED
	select LICHEN_GATEWAY_PREFIX_DELEGATION
	help
	  WiFi STA backhaul for Heltec V3 / T-Deck gateways (spec/appendix-border-router.md). Enables
	  LICHEN_GATEWAY_PREFIX_DELEGATION + net_mgmt handlers for connection and prefix events.
	  SSID/PSK configurable via Kconfig or /config CoAP. Follows AGENTS.md subsystem init order.

endmenu

source "Kconfig.zephyr"
