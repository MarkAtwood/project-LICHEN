menu "LICHEN Gateway"

config LORA_LICHEN_BLE
	bool "Native BLE LCI interface"
	depends on BT
	depends on BT_PERIPHERAL
	depends on BT_MAX_CONN = 1
	select NET_L2_DUMMY
	default n
	help
	  Enable the native LICHEN BLE Local Client Interface so a phone can
	  exchange SLIP-framed IPv6 packets with the gateway over BLE GATT.
	  By default this uses LICHEN-specific service and characteristic UUIDs.
	  Gate per board: enable only on targets with an enabled Zephyr BLE HCI
	  device. Keep the HAL BLE-local capability disabled until the board has a
	  validated bidirectional local-client transport.

config LORA_LICHEN_BLE_LEGACY_NUS
	bool "Use legacy Nordic UART Service UUIDs for native BLE LCI"
	depends on LORA_LICHEN_BLE
	default n
	help
	  Keep the native LICHEN BLE LCI surface on the Nordic UART Service UUID
	  triplet for existing mutually exclusive native product images. Do not
	  enable this in images that also need MeshCore compatibility: MeshCore
	  owns NUS UUIDs with raw MeshCore frame semantics.

config NET_IF_MAX_IPV6_COUNT
	default 2 if LORA_LICHEN_BLE

config LORA_LICHEN_MESHTASTIC_BLE
	bool "Meshtastic-compatible BLE GATT interface"
	depends on BT
	depends on BT_PERIPHERAL
	depends on BT_MAX_CONN = 1
	depends on LICHEN_MESHTASTIC_CODEC
	depends on LICHEN_LINK
	depends on !LORA_LICHEN_BLE
	select LICHEN_APP_IDENTITY
	select LICHEN_APP_INTERFACE
	select LICHEN_MESHTASTIC_ADAPTER
	default n
	help
	  Enable the Meshtastic BLE service UUID and raw protobuf
	  ToRadio/FromRadio/FromNum characteristics. This is a local app
	  compatibility surface only; it does not make LICHEN RF packets
	  Meshtastic-compatible. The first implementation owns a single
	  Meshtastic app session and therefore requires CONFIG_BT_MAX_CONN=1.
	  App identity is selected so NodeDB sync can enumerate known LICHEN
	  peers through the common app-visible identity table.

config LORA_LICHEN_MESHCORE_BLE
	bool "MeshCore-compatible BLE GATT interface"
	depends on BT
	depends on BT_PERIPHERAL
	depends on BT_MAX_CONN = 1
	depends on BT_SMP || ZTEST
	depends on BT_FIXED_PASSKEY || ZTEST
	depends on LICHEN_MESHCORE_CODEC
	depends on LICHEN_LINK
	depends on !LORA_LICHEN_BLE
	depends on !LORA_LICHEN_MESHTASTIC_BLE
	select LICHEN_APP_IDENTITY
	select LICHEN_APP_INTERFACE
	select LICHEN_MESHCORE_ADAPTER
	select BT_SMP_ENFORCE_MITM if !ZTEST
	default n
	help
	  Enable the MeshCore-compatible Nordic UART Service UUIDs with raw
	  MeshCore command/response frames. This is a local app compatibility
	  surface only; it does not make LICHEN RF packets MeshCore-compatible.
	  The first implementation owns a single MeshCore app session, requires
	  CONFIG_BT_MAX_CONN=1, CONFIG_BT_SMP, and CONFIG_BT_FIXED_PASSKEY. It
	  uses authenticated encrypted GATT access in production builds. Plain
	  permissions are limited to ztest/native_sim test builds.

config LORA_LICHEN_MESHCORE_BLE_QUEUE_DEPTH
	int "MeshCore BLE frame queue depth"
	depends on LORA_LICHEN_MESHCORE_BLE
	default 4
	range 1 16
	help
	  Number of complete raw MeshCore frames retained for app RX and TX.

config LORA_LICHEN_MESHCORE_BLE_NAME
	string "MeshCore BLE advertised name"
	depends on LORA_LICHEN_MESHCORE_BLE
	default "MeshCore-LICHEN"
	help
	  Short advertised name used only in MeshCore compatibility mode. Keep
	  the default MeshCore- prefix unless real-client smoke tests prove
	  another prefix is discoverable.

config LORA_LICHEN_MESHCORE_BLE_PASSKEY
	int "MeshCore BLE fixed pairing passkey"
	depends on LORA_LICHEN_MESHCORE_BLE
	default 123456
	range 0 999999
	help
	  Six-digit MeshCore compatibility passkey installed with
	  bt_passkey_set() before advertising starts. This is the first
	  product-mode hook for authenticated local pairing; production boards
	  should override it from provisioning or persistent settings once the
	  MeshCore config-secret policy is implemented.

config LORA_LICHEN_MESHTASTIC_BLE_QUEUE_DEPTH
	int "Meshtastic BLE FromRadio queue depth"
	depends on LORA_LICHEN_MESHTASTIC_BLE
	default 20
	range LORA_LICHEN_MESHTASTIC_BLE_QUEUE_DEPTH_MIN 32
	help
	  Number of complete FromRadio protobuf values retained for app reads.
	  Keep enough headroom for a queued heartbeat plus a full configuration
	  sync burst with the default bounded NodeDB peer cap.

config LORA_LICHEN_MESHTASTIC_BLE_QUEUE_DEPTH_MIN
	int
	default 20

config LICHEN_APP_INTERFACE_MAX_PAYLOAD
	int
	default 200 if LORA_LICHEN_MESHTASTIC_BLE

config LORA_LICHEN_MESHTASTIC_BLE_TO_RADIO_QUEUE_DEPTH
	int "Meshtastic BLE ToRadio queue depth"
	depends on LORA_LICHEN_MESHTASTIC_BLE
	default 8
	range 1 16
	help
	  Number of complete ToRadio protobuf values retained for gateway
	  processing after app writes.

config LORA_LICHEN_GATEWAY_MESSAGE_QUEUE_DEPTH
	int "Gateway local message ingress queue depth"
	depends on LORA_LICHEN_MESHTASTIC_BLE || LORA_LICHEN_MESHCORE_BLE
	default 4
	range 1 16
	help
	  Number of app-ingress text messages accepted from compatibility
	  surfaces and retained for the normal LICHEN message sender. Until that
	  sender is enabled, this bounded queue is the deterministic local
	  contract and does not transmit on BLE or LoRa by itself.

config LORA_LICHEN_GATEWAY_RPL_ROOT
	bool "RPL root signalling"
	depends on LICHEN_RPL
	depends on BROKEN
	default n
	help
	  Enable gateway DIO/DAO processing and root signalling.

	  This is intentionally unavailable until the gateway has an app-level
	  packet I/O integration that drives the caller-owned LICHEN RPL state
	  machine. With this option disabled, the gateway advertises itself as
	  non-RPL-capable in /status so users do not mistake it for a complete
	  mesh root.

endmenu

source "Kconfig.zephyr"
