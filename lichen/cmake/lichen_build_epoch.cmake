function(_lichen_time_build_epoch_validate _name _value _out_error)
  set(_error "")
  if("${_value}" STREQUAL "")
    set(_error "${_name} is empty")
  elseif(NOT "${_value}" MATCHES "^[0-9]+$")
    set(_error "${_name} must be an unsigned Unix timestamp, got '${_value}'")
  elseif(_value LESS 1 OR _value GREATER 2147483647)
    set(_error "${_name} must be in range 1..2147483647, got '${_value}'")
  endif()

  set(${_out_error} "${_error}" PARENT_SCOPE)
endfunction()

function(lichen_time_build_epoch_resolve)
  set(_options ALLOW_FAILURE)
  set(_one_value MODE RELEASE_EPOCH DEVELOPER_EPOCH OUT_EPOCH OUT_SOURCE OUT_GENERATED OUT_ERROR)
  cmake_parse_arguments(ARG "${_options}" "${_one_value}" "" ${ARGN})

  if(ARG_MODE)
    set(_mode "${ARG_MODE}")
  else()
    set(_mode "production")
  endif()

  set(_epoch "")
  set(_source "")
  set(_generated FALSE)
  set(_error "")

  if(_mode STREQUAL "production")
    if(DEFINED ENV{SOURCE_DATE_EPOCH} AND NOT "$ENV{SOURCE_DATE_EPOCH}" STREQUAL "")
      set(_epoch "$ENV{SOURCE_DATE_EPOCH}")
      set(_source "SOURCE_DATE_EPOCH")
    elseif(DEFINED ARG_RELEASE_EPOCH AND NOT "${ARG_RELEASE_EPOCH}" STREQUAL "")
      set(_epoch "${ARG_RELEASE_EPOCH}")
      set(_source "RELEASE")
    else()
      set(_error "Production LICHEN firmware requires SOURCE_DATE_EPOCH or -DLICHEN_RELEASE_EPOCH_UNIX=<unix-seconds> for CONFIG_LICHEN_TIME_BUILD_EPOCH_UNIX")
    endif()
  elseif(_mode STREQUAL "developer-generated")
    if(DEFINED ARG_DEVELOPER_EPOCH AND NOT "${ARG_DEVELOPER_EPOCH}" STREQUAL "")
      set(_epoch "${ARG_DEVELOPER_EPOCH}")
      set(_source "DEVELOPER_FIXED")
    else()
      string(TIMESTAMP _epoch "%s" UTC)
      set(_generated TRUE)
      set(_source "DEVELOPER_GENERATED")
    endif()
  else()
    set(_error "Unsupported LICHEN_TIME_BUILD_EPOCH_MODE='${_mode}' (expected production or developer-generated)")
  endif()

  if(_error STREQUAL "")
    _lichen_time_build_epoch_validate("LICHEN time build epoch" "${_epoch}" _validate_error)
    if(NOT _validate_error STREQUAL "")
      set(_error "${_validate_error}")
    endif()
  endif()

  if(ARG_ALLOW_FAILURE AND NOT _error STREQUAL "")
    if(ARG_OUT_ERROR)
      set(${ARG_OUT_ERROR} "${_error}" PARENT_SCOPE)
    endif()
    return()
  elseif(NOT _error STREQUAL "")
    message(FATAL_ERROR "${_error}")
  endif()

  if(ARG_OUT_EPOCH)
    set(${ARG_OUT_EPOCH} "${_epoch}" PARENT_SCOPE)
  endif()
  if(ARG_OUT_SOURCE)
    set(${ARG_OUT_SOURCE} "${_source}" PARENT_SCOPE)
  endif()
  if(ARG_OUT_GENERATED)
    set(${ARG_OUT_GENERATED} "${_generated}" PARENT_SCOPE)
  endif()
  if(ARG_OUT_ERROR)
    set(${ARG_OUT_ERROR} "" PARENT_SCOPE)
  endif()
endfunction()

function(lichen_configure_time_build_epoch)
  set(_mode "${LICHEN_TIME_BUILD_EPOCH_MODE}")
  if(_mode STREQUAL "")
    set(_mode "production")
  endif()

  lichen_time_build_epoch_resolve(
    MODE "${_mode}"
    RELEASE_EPOCH "${LICHEN_RELEASE_EPOCH_UNIX}"
    DEVELOPER_EPOCH "${LICHEN_DEVELOPER_BUILD_EPOCH_UNIX}"
    OUT_EPOCH _epoch
    OUT_SOURCE _source
    OUT_GENERATED _generated
  )

  set(_conf_dir "${CMAKE_CURRENT_BINARY_DIR}/lichen")
  set(_conf_file "${_conf_dir}/build_epoch.conf")
  file(MAKE_DIRECTORY "${_conf_dir}")
  file(WRITE "${_conf_file}" "CONFIG_LICHEN_TIME_BUILD_EPOCH_UNIX=${_epoch}\n")
  if(_source STREQUAL "SOURCE_DATE_EPOCH")
    file(APPEND "${_conf_file}" "CONFIG_LICHEN_TIME_BUILD_EPOCH_SOURCE_DATE_EPOCH=y\n")
  elseif(_source STREQUAL "RELEASE")
    file(APPEND "${_conf_file}" "CONFIG_LICHEN_TIME_BUILD_EPOCH_SOURCE_RELEASE=y\n")
  elseif(_source STREQUAL "DEVELOPER_GENERATED")
    file(APPEND "${_conf_file}" "CONFIG_LICHEN_TIME_BUILD_EPOCH_SOURCE_DEVELOPER_GENERATED=y\n")
  elseif(_source STREQUAL "DEVELOPER_FIXED")
    file(APPEND "${_conf_file}" "CONFIG_LICHEN_TIME_BUILD_EPOCH_SOURCE_DEVELOPER_FIXED=y\n")
  endif()

  list(APPEND EXTRA_CONF_FILE "${_conf_file}")
  set(EXTRA_CONF_FILE "${EXTRA_CONF_FILE}" CACHE STRING "Additional Kconfig fragments" FORCE)
  set(LICHEN_TIME_BUILD_EPOCH_RESOLVED "${_epoch}" CACHE INTERNAL "Resolved LICHEN firmware build epoch")
  set(LICHEN_TIME_BUILD_EPOCH_SOURCE_RESOLVED "${_source}" CACHE INTERNAL "Resolved LICHEN firmware build epoch source")
  set(LICHEN_TIME_BUILD_EPOCH_GENERATED "${_generated}" CACHE INTERNAL "Whether the LICHEN firmware build epoch was generated by CMake")
endfunction()
