config LICHEN_NATIVE
	bool "Legacy LICHEN Native CBOR protocol library"
	depends on LICHEN_HAL
	depends on UART_INTERRUPT_DRIVEN
	depends on ZCBOR
	help
	  Enables the historical LICHEN Native framing library (0xC1 + CBOR
	  over USB CDC-ACM or serial UART). This is not the current LCI app
	  contract; new local-client transports carry IPv6 packets and use
	  CoAP resources from spec/11-lci.md. Runtime transport discovery
	  uses the LICHEN HAL serial-local API.

if LICHEN_NATIVE

config LICHEN_NATIVE_TX_BUF_SIZE
	int "TX scratch buffer (bytes)"
	default 512
	help
	  Scratch buffer used to encode one outgoing CBOR frame.
	  Must be large enough for the largest message you send.

config LICHEN_NATIVE_RX_BUF_SIZE
	int "RX reassembly buffer (bytes)"
	default 512
	help
	  Buffer for incoming frame payload reassembly.

config LICHEN_NATIVE_RX_STACK_SIZE
	int "RX thread stack size (bytes)"
	default 1024

config LICHEN_NATIVE_BUZZER
	bool "Enable startup buzzer beeps (T1000-E only)"
	default n
	help
	  Emit two beep tones via P0.25/P1.05 on native transport init.
	  Only for T1000-E which has a buzzer; must not be set on boards
	  where P0.25 is used for another purpose (e.g. T-Echo LoRa RESET).

endif # LICHEN_NATIVE
