#
# clang-tidy configuration for LICHEN C code
# Policy: spec/appendix-c-safety.md

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  misc-*,
  performance-*,
  readability-braces-around-statements,
  readability-inconsistent-declaration-parameter-name,
  readability-misleading-indentation,
  readability-redundant-*,
  -bugprone-easily-swappable-parameters,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -misc-no-recursion,
  -misc-include-cleaner,
  -misc-redundant-expression,
  -misc-unused-parameters,
  -misc-header-include-cycle,
  -bugprone-not-null-terminated-result,
  -clang-diagnostic-conversion,
  -clang-analyzer-optin.core.EnumCastOutOfRange

# Checks disabled in the 2mla curation (lora_ipv6_mesh-2mla):
#   misc-include-cleaner: Zephyr umbrella headers (kernel.h et al) make
#     direct-include analysis pure noise (441 findings).
#   misc-redundant-expression: false-positives on side-effectful sequential
#     calls (zcbor_any_skip twice = skip key, skip value) and on Zephyr
#     COND_CODE_1 chains that collapse to 0|0 in a given config.
#   misc-unused-parameters: config-conditional parameters; mirrors the
#     project's -Wno-unused-parameter compiler policy.
#   misc-header-include-cycle: fires inside Zephyr's tracing headers.
#   bugprone-not-null-terminated-result: misfires on memcpy into binary
#     CBOR buffers that must not be NUL-terminated.
#   clang-diagnostic-conversion: mirrors the GCC hardening policy of
#     -Wconversion as warning, not error (-Wno-error=conversion).
#   clang-analyzer-optin.core.EnumCastOutOfRange: fires on idiomatic
#     flag-enum bitwise-OR (e.g. NET_L2_MULTICAST | NET_L2_MULTICAST_SKIP_
#     JOIN_SOLICIT_NODE) — the same pattern Zephyr's own L2 drivers use
#     (subsys/net/l2/openthread/openthread.c). Real out-of-range casts are
#     caught by -Wswitch/enum coverage; the one genuine finding here
#     (coap_client method left 0 by {0} init) is fixed at the source.

WarningsAsErrors: '*'

CheckOptions:
  - key: readability-braces-around-statements.ShortStatementLines
    value: 1
