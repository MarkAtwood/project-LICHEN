CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

# 32 kHz crystal is populated on the nRF52840 module.
CONFIG_CLOCK_CONTROL_NRF_K32SRC_XTAL=y

CONFIG_GPIO=y
CONFIG_SPI=y
CONFIG_I2C=y
CONFIG_ADC=y
CONFIG_SERIAL=y

# Native USB CDC-ACM console.
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_CDC_ACM=y
CONFIG_UART_CONSOLE=y
CONFIG_CONSOLE=y
