 /dts-v1/;

#include <espressif/esp32s3/esp32s3_wroom_n16r8.dtsi>
#include "t_deck-pinctrl.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/lora/sx126x.h>
#include <zephyr/dt-bindings/mipi_dbi/mipi_dbi.h>

/ {
	model = "Lilygo T-Deck PROCPU";
	compatible = "lilygo,t-deck";

	aliases {
		led0      = &led0;
		sw0       = &button0;
		lora0     = &lora0;
		watchdog0 = &wdt0;
	};

	chosen {
		zephyr,sram           = &sram0;
		zephyr,console        = &uart0;
		zephyr,shell-uart     = &uart0;
		zephyr,flash          = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,bt-hci         = &esp32_bt_hci;
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			/* T-Deck has no user LED; reuse display backlight GPIO */
			gpios = <&gpio1 10 GPIO_ACTIVE_HIGH>; /* GPIO42 */
			label = "LCD_BL";
		};
	};

	buttons {
		compatible = "gpio-keys";
		button0: button_0 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "PRG";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	power_monitor {
		compatible = "lichen,poe-pg";
		pg-gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;
		status = "okay";
	};

	tdeck_mipi_dbi: mipi-dbi {
		compatible = "zephyr,mipi-dbi-spi";
		spi-dev = <&spi3>;
		dc-gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
		write-only;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "disabled";

		tdeck_display: st7789v@1 {
			compatible = "sitronix,st7789v";
			reg = <1>;
			status = "disabled";
			mipi-max-frequency = <20000000>;

			width = <240>;
			height = <320>;
			x-offset = <0>;
			y-offset = <0>;

			vcom = <0x28>;
			gctrl = <0x35>;
			vrhs = <0x10>;
			vdvs = <0x20>;
			mdac = <0x00>;
			gamma = <0x01>;
			colmod = <0x55>;
			lcm = <0x2c>;
			porch-param = [0c 0c 00 33 33];
			cmd2en-param = [5a 69 02 00];
			pwctrl1-param = [a4 a1];
			pvgam-param = [d0 00 02 07 0a 28 32 44 42 06 0e 12 14 17];
			nvgam-param = [d0 00 02 07 0a 28 31 54 47 0e 1c 17 1b 1e];
			ram-param = [00 f0];
			rgb-param = [40 02 14];
			mipi-mode = <MIPI_DBI_MODE_SPI_4WIRE>;
		};
	};
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&gpio0 {
	status = "okay";

	/*
	 * GPIO10 enables the T-Deck peripheral rail.  LilyGO and Meshtastic
	 * sources both assert it before using the keyboard controller, display,
	 * SD card, trackball, audio devices, or radio-adjacent peripherals.
	 */
	periph-pwr-hog {
		gpio-hog;
		gpios = <10 GPIO_ACTIVE_HIGH>;
		output-high;
	};

	/*
	 * The ST7789 display shares SPI3 with LoRa and SD.  Keep its CS
	 * deselected until an overlay enables the display node and removes
	 * this hog so SPI can own CS1.
	 */
	t_deck_tft_cs_hog: tft-cs-hog {
		gpio-hog;
		gpios = <12 GPIO_ACTIVE_LOW>;
		output-low;
	};
};

&gpio1 {
	status = "okay";

	/*
	 * The SD card also shares SPI3.  Keep CS inactive until an overlay
	 * enables storage and removes this hog so SPI can own CS2.
	 */
	t_deck_sd_cs_hog: sd-cs-hog {
		gpio-hog;
		gpios = <7 GPIO_ACTIVE_LOW>; /* GPIO39 = gpio1[7] */
		output-low;
	};
};

/*
 * SX1262 LoRa radio on SPI3.
 *   CS=GPIO9  RESET=GPIO17  BUSY=GPIO13  DIO1=GPIO45
 *   DIO2 drives the internal RF TX/RX switch (dio2-tx-enable).
 *   DIO3 supplies the module TCXO at 1.8 V.
 */
&spi3 {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";
	pinctrl-0 = <&spim3_default>;
	pinctrl-names = "default";
	cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>,
		   <&gpio0 12 GPIO_ACTIVE_LOW>,
		   <&gpio1 7 GPIO_ACTIVE_LOW>; /* GPIO39 = gpio1[7] */

	lora0: lora@0 {
		compatible = "semtech,sx1262";
		reg = <0>;
		reset-gpios = <&gpio0 17 (GPIO_OPEN_DRAIN | GPIO_ACTIVE_LOW)>;
		busy-gpios  = <&gpio0 13 GPIO_ACTIVE_HIGH>;
		dio1-gpios  = <&gpio1 13 GPIO_ACTIVE_HIGH>; /* GPIO45 = gpio1[13] */
		dio2-tx-enable;
		dio3-tcxo-voltage = <SX126X_DIO3_TCXO_1V8>;
		tcxo-power-startup-delay-ms = <5>;
		spi-max-frequency = <16000000>;
	};

	tdeck_sd: sd@2 {
		compatible = "zephyr,sdhc-spi-slot";
		reg = <2>;
		status = "disabled";
		spi-max-frequency = <12000000>;
		mmc {
			compatible = "zephyr,sdmmc-disk";
			status = "disabled";
		};
	};
};

&timer0 { status = "okay"; };
&timer1 { status = "okay"; };
&timer2 { status = "okay"; };
&timer3 { status = "okay"; };

&wdt0 {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&flash0 {
	status = "okay";
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Reserve 64 kB for the bootloader */
		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 0x00010000>;
			read-only;
		};
		/* Application slot 0 (4 MiB): sized for BLE/LVGL/UI growth. */
		slot0_partition: partition@10000 {
			label = "image-0";
			reg = <0x00010000 0x00400000>;
		};
		/* Application slot 1 (4 MiB): same size for swap/OTA images. */
		slot1_partition: partition@410000 {
			label = "image-1";
			reg = <0x00410000 0x00400000>;
		};
		/* MCUboot scratch (512 KiB). */
		scratch_partition: partition@810000 {
			label = "image-scratch";
			reg = <0x00810000 0x00080000>;
		};
		/* NVS / LittleFS storage for config, keys, queues, and state. */
		storage_partition: partition@890000 {
			label = "storage";
			reg = <0x00890000 0x00400000>;
		};
		/* UI assets and optional offline resources. */
		assets_partition: partition@c90000 {
			label = "assets";
			reg = <0x00c90000 0x00300000>;
		};
		/* Field logs, crash exports, and bring-up captures. */
		logs_partition: partition@f90000 {
			label = "logs";
			reg = <0x00f90000 0x00070000>;
		};
	};
};
