      "input": {
        "eui64": "0011223344556677",
        "epoch": 0,
        "density": 9,
        "snr_db": -1,
        "now": 4294967280
      },
      "output": {
        "hash_32": 2271500941,
        "channel": 0,
        "expected_channel": 0,
        "sf": 11,
        "select_channel": 0,
        "now": 4294967280
      }
    },
    {
      "name": "select_channel_sf12_high_density",
      "description": "density>20 triggers sf=12 (max SF). Channel forced to 0 by density>8.",
      "type": "slot_selection",
      "input": {
        "eui64": "0011223344556677",
        "epoch": 0,
        "density": 25,
        "snr_db": 5,
        "now": 0
