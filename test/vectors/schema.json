{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LICHEN test vector file (v1 and v2)",
  "description": "Envelope shared by all LICHEN vector files (supports format_version 1 and 2 for backward compatibility with existing v1 vectors). Supports bare array root for v2 CCP vectors (ccp16-desync.json). New CCP-9 vector family added to ccp_vector definition with rendezvous fields. Each file holds a list of vectors of one kind; see the per-vector definitions.",
  "oneOf": [
    {
      "type": "object",
      "required": ["description", "vectors"],
      "properties": {
        "format_version": {"type": "integer", "enum": [1, 2]},
        "description": {"type": "string"},
        "$schema": {"type": "string"},
        "name": {"type": "string"},
        "spec": {"type": "string"},
        "vectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {"$ref": "#/definitions/schc_vector"},
              {"$ref": "#/definitions/l2_payload_vector"},
              {"$ref": "#/definitions/frame_vector"},
              {"$ref": "#/definitions/announce_coords_vector"},
              {"$ref": "#/definitions/meshtastic_app_compat_vector"},
              {"$ref": "#/definitions/meshcore_app_compat_vector"},
              {"$ref": "#/definitions/oscore_vector"},
              {"$ref": "#/definitions/rpl_messages_vector"},
              {"$ref": "#/definitions/schc_fragment_vector"},
              {"$ref": "#/definitions/deaddrop_vector"},
              {"$ref": "#/definitions/ccp_vector"},
              {"$ref": "#/definitions/compact_cot_vector"},
              {"$ref": "#/definitions/schnorr_vector"}
            ]
          }
        }
      },
      "additionalProperties": false
    },
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {"$ref": "#/definitions/ccp_vector"}
        ]
      },
      "description": "v2 bare array root support for CCP desync vectors (ccp16-desync.json)"
    }
  ],
  "definitions": {
    "hex": {
      "type": "string",
      "pattern": "^([0-9a-f][0-9a-f])*$",
      "description": "Lowercase hex-encoded byte string (may be empty)."
    },
    "schc_vector": {
      "type": "object",
      "required": ["name", "rule_id", "packet", "compressed"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "expect": {
                "required": ["response_prefix"]
              }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["response_len"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "rule_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "description": {"type": "string"},
        "packet": {"$ref": "#/definitions/hex",
          "description": "Full uncompressed IPv6 datagram."},
        "compressed": {"$ref": "#/definitions/hex",
          "description": "SCHC output: leading rule-id byte + residue + tail."}
      }
    },
    "announce_coords_vector": {
      "type": "object",
      "required": ["name", "latitude_degrees", "longitude_degrees", "latitude_e7", "longitude_e7", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "latitude_degrees": {"type": "number", "minimum": -90, "maximum": 90},
        "longitude_degrees": {"type": "number", "minimum": -180, "maximum": 180},
        "latitude_e7": {"type": "integer", "minimum": -900000000, "maximum": 900000000},
        "longitude_e7": {"type": "integer", "minimum": -1800000000, "maximum": 1800000000},
        "encoded": {
          "type": "string",
          "pattern": "^01[0-9a-f]{16}$",
          "description": "Announce app_data Type=0x01 bytes: type + signed big-endian lat_e7 + signed big-endian lon_e7."
        }
      }
    },
    "l2_payload_vector": {
      "type": "object",
      "required": ["name", "dispatch", "kind", "body", "wrapped"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "dispatch": {"type": "integer", "minimum": 0, "maximum": 255},
        "kind": {"type": "string", "enum": ["schc", "routing", "unknown"]},
        "body": {"$ref": "#/definitions/hex",
          "description": "Payload bytes after the dispatch byte."},
        "wrapped": {"$ref": "#/definitions/hex",
          "description": "Authenticated link inner payload: dispatch byte + body."}
      }
    },
    "frame_vector": {
      "type": "object",
      "required": ["name", "fields", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "required": ["epoch", "seqnum", "dst_addr", "payload", "mic",
                       "addr_mode", "mic_length", "signature_present", "encrypted"],
          "properties": {
            "epoch": {"type": "integer", "minimum": 0, "maximum": 255},
            "seqnum": {"type": "integer", "minimum": 0, "maximum": 65535},
            "dst_addr": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"},
            "mic": {"$ref": "#/definitions/hex"},
            "addr_mode": {"type": "integer", "minimum": 0, "maximum": 3},
            "mic_length": {"type": "integer", "minimum": 0, "maximum": 1},
            "signature_present": {"type": "boolean"},
            "encrypted": {"type": "boolean"}
          }
        },
        "encoded": {"$ref": "#/definitions/hex",
          "description": "On-air frame bytes (length-prefixed)."},
        "expect": {
          "type": "object",
          "required": ["error"],
          "additionalProperties": false,
          "properties": {"error": {"type": "string"}}
        }
      }
    },
    "meshtastic_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "protobuf",
        "message",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"message": {"const": "want_config_id"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_sequence", "terminal_from_radio"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "enum": [
                  "want_config_stage_69420",
                  "legacy_full_sync_unknown_nonce"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": [
                  "from_radio_sequence",
                  "config_sections",
                  "terminal_from_radio"
                ]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"enum": ["invalid_stream_framing", "oversized"]}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["reject"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.PRIVATE_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["unsupported", "side_effect"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.ROUTING_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["delivery_status"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["packet.TEXT_MESSAGE_APP", "packet.ROUTING_APP"]}
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_id"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["config", "moduleConfig", "region_presets"]}
            }
          },
          "then": {
            "required": ["payload"],
            "properties": {
              "expect": {
                "required": ["from_radio_field"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "FromNum"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["byte_order", "read_until_empty"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "Empty"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["queue_drained", "no_from_num_increment"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["protobufs", "firmware", "python", "android", "apple"],
          "additionalProperties": false,
          "properties": {
            "protobufs": {"type": "string"},
            "firmware": {"type": "string"},
            "python": {"type": "string"},
            "android": {"type": "string"},
            "apple": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing", "reject_prefix_hex"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string"},
            "framing": {"type": "string"},
            "reject_prefix_hex": {"$ref": "#/definitions/hex"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "protobuf": {"type": "string", "enum": ["ToRadio", "FromRadio", "FromNum", "Empty"]},
        "message": {"type": "string"},
        "encoded": {"$ref": "#/definitions/hex"},
        "payload": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "properties": {
            "delivery_status": {"type": "string", "enum": ["ack", "nak"]},
            "from_radio_field": {"type": "integer", "minimum": 1},
            "from_radio_id": {"type": "integer", "minimum": 1},
            "from_radio_sequence": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            },
            "config_sections": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["section", "oneof_field", "payload", "fields"],
                "additionalProperties": false,
                "properties": {
                  "section": {"type": "string"},
                  "oneof_field": {"type": "integer", "minimum": 1},
                  "payload": {"$ref": "#/definitions/hex"},
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["field", "wire_type", "value"],
                      "additionalProperties": false,
                      "properties": {
                        "field": {"type": "integer", "minimum": 1},
                        "wire_type": {"type": "string", "enum": ["varint"]},
                        "value": {"type": "integer", "minimum": 0}
                      }
                    },
                    "minItems": 1
                  }
                }
              },
              "minItems": 1
            },
            "config_section": {
              "type": "object",
              "required": ["section", "oneof_field", "payload", "fields"],
              "additionalProperties": false,
              "properties": {
                "section": {"type": "string"},
                "oneof_field": {"type": "integer", "minimum": 1},
                "payload": {"$ref": "#/definitions/hex"},
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["field", "wire_type", "value"],
                    "additionalProperties": false,
                    "properties": {
                      "field": {"type": "integer", "minimum": 1},
                      "wire_type": {"type": "string", "enum": ["varint"]},
                      "value": {"type": "integer", "minimum": 0}
                    }
                  },
                  "minItems": 1
                }
              }
            },
            "max_to_radio_bytes": {"type": "integer", "minimum": 1},
            "must_not_require_before_sync": {"type": "boolean"},
            "byte_order": {"type": "string", "enum": ["little-endian"]},
            "no_from_num_increment": {"type": "boolean"},
            "queue_side_effect": {"type": "string"},
            "queue_drained": {"type": "boolean"},
            "reason": {"type": "string"},
            "read_until_empty": {"type": "boolean"},
            "response_to": {"type": "string"},
            "reject": {"type": "boolean"},
            "response": {"type": "string"},
            "side_effect": {"type": "string"},
            "terminal_from_radio": {"$ref": "#/definitions/hex"},
            "unsupported": {"type": "boolean"}
          }
        }
      }
    },
    "meshcore_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "frame",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["firmware", "flutter", "python", "cli", "js"],
          "additionalProperties": false,
          "properties": {
            "firmware": {"type": "string"},
            "flutter": {"type": "string"},
            "python": {"type": "string"},
            "cli": {"type": "string"},
            "js": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string", "enum": ["ble-nus", "serial"]},
            "framing": {"type": "string"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "frame": {"type": "string", "enum": ["command", "response", "push", "serial"]},
        "encoded": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "adapter_test": {"type": "boolean"},
            "compat_store": {"type": "string"},
            "drift_note": {"type": "string"},
            "emitted_by": {"type": "string"},
            "fixture": {"type": "string"},
            "inner_frame": {"$ref": "#/definitions/hex"},
            "preceded_by": {"type": "string"},
            "response_len": {"type": "integer", "minimum": 0},
            "response_prefix": {"$ref": "#/definitions/hex"},
            "response_to": {"type": "string"},
            "responses": {
              "type": "array",
              "items": {"$ref": "#/definitions/hex"},
              "minItems": 1
            }
          }
        }
      }
    },
    "oscore_vector": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "description": "OSCORE (RFC 8613) test vector for key derivation, request/response protection, replay detection, or invalid input.",
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["key_derivation", "request_protection", "response_protection", "roundtrip", "replay", "invalid"]
        },
        "description": {"type": "string"},
        "master_secret": {"$ref": "#/definitions/hex", "description": "16-byte master secret (AES-128)"},
        "master_salt": {
          "oneOf": [{"$ref": "#/definitions/hex"}, {"type": "null"}],
          "description": "Optional master salt (up to 8 bytes)"
        },
        "sender_id": {"$ref": "#/definitions/hex", "description": "Sender ID (up to 7 bytes)"},
        "recipient_id": {"$ref": "#/definitions/hex", "description": "Recipient ID (up to 7 bytes)"},
        "id_context": {
          "oneOf": [{"$ref": "#/definitions/hex"}, {"type": "null"}],
          "description": "Optional ID Context"
        },
        "algorithm": {
          "type": "integer",
          "description": "COSE algorithm ID (10 = AES-CCM-16-64-128)"
        },
        "sender_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sender sequence number for protection"
        },
        "request_piv": {
          "$ref": "#/definitions/hex",
          "description": "Request Partial IV (for response protection)"
        },
        "request_kid": {
          "$ref": "#/definitions/hex",
          "description": "Request KID (for response AAD)"
        },
        "plaintext": {
          "type": "object",
          "description": "Plaintext CoAP message components",
          "properties": {
            "code": {"type": "integer", "minimum": 0, "maximum": 255},
            "options": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"}
          }
        },
        "ciphertext": {"$ref": "#/definitions/hex"},
        "highest_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Highest seen sequence number (replay tests)"
        },
        "window_bits": {
          "type": "integer",
          "minimum": 0,
          "description": "Replay window bitmask (replay tests)"
        },
        "test_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sequence number to test (replay tests)"
        },
        "expected": {
          "type": "object",
          "description": "Expected results",
          "properties": {
            "sender_key": {"$ref": "#/definitions/hex"},
            "recipient_key": {"$ref": "#/definitions/hex"},
            "common_iv": {"$ref": "#/definitions/hex"},
            "oscore_option": {"$ref": "#/definitions/hex"},
            "ciphertext": {"$ref": "#/definitions/hex"},
            "is_replay": {"type": "boolean"},
            "new_highest": {"type": "integer"},
            "new_window": {"type": "integer"}
          }
        },
        "expected_error": {
          "type": "string",
          "enum": ["invalid_param", "decrypt_failed", "replay", "seq_exhausted"]
        }
      }
    },
    "rpl_messages_vector": {
      "type": "object",
      "required": ["name", "type", "encoded"],
      "additionalProperties": false,
      "description": "RPL control message (RFC 6550) parse/generate vector.",
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["dio", "dao", "dao_ack", "dis", "option", "dio_with_options", "dao_with_options", "option_chain"],
          "description": "Message or option type being tested"
        },
        "option_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "RPL option type (for type=option vectors)"
        },
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "description": "Decoded message fields (structure varies by type)"
        },
        "options": {
          "type": "array",
          "description": "Option chain (for type=option_chain vectors)",
          "items": {"type": "object"}
        },
        "encoded": {
          "$ref": "#/definitions/hex",
          "description": "Encoded message bytes (excluding ICMPv6 header)"
        }
      }
    },
    "schc_fragment_vector": {
      "type": "object",
      "required": ["name", "description", "rule_id", "packet", "fragments"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "rule_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "packet": {"$ref": "#/definitions/hex", "description": "Uncompressed payload to fragment (independent from compression)."},
        "fragments": {
          "type": "array",
          "items": {"$ref": "#/definitions/hex"},
          "description": "Expected SCHC fragment bytes in transmission order (from RFC 8724 §8 or external oracle)."
        },
        "mode": {"type": "string", "enum": ["no_ack", "ack_on_error", "ack_always"]},
        "mic": {"$ref": "#/definitions/hex", "description": "Expected MIC for All-1 (CRC32)."},
        "acks": {
          "type": "array",
          "items": {"$ref": "#/definitions/hex"},
          "description": "Expected ACK bitmaps or responses for ACK-on-error cases."
        },
        "expect": {
          "type": "object",
          "properties": {
            "mic_fail": {"type": "boolean"},
            "out_of_order": {"type": "boolean"},
            "retransmits": {"type": "array", "items": {"type": "integer"}},
            "abort_after_attempts": {"type": "integer", "description": "Per RFC 8724 8.4.3.2: ACK then abort on exceeding MAX_ACK_REQUESTS (not immediate abort on 5th)."}
          }
        }
      }
    },
    "deaddrop_vector": {
      "type": "object",
      "required": ["name", "type", "description", "recipient", "ciphertext", "ttl", "encoded"],
      "additionalProperties": false,
      "description": "Independent test vectors for /deaddrop DTN endpoint (POST submission, GET pickup). Aligns with oscore.json for OSCORE-wrapped ciphertexts and RFC 8428 SenML for message content. Uses external RFC oracles only.",
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["post_submission", "pickup", "rejection", "oscore_wrapped"]
        },
        "description": {"type": "string"},
        "recipient": {"type": "string", "description": "Node ID or EUI for recipient"},
        "ciphertext": {"$ref": "#/definitions/hex", "description": "OSCORE-protected payload (cross-ref oscore.json)"},
        "ttl": {"type": "integer", "minimum": 0},
        "encoded": {"$ref": "#/definitions/hex", "description": "Full CoAP request/response bytes (independent oracle from RFC 7252 + OSCORE)"},
        "senml_payload": {"$ref": "#/definitions/hex", "description": "Optional SenML-CBOR inside ciphertext (RFC 8428)"},
        "expected": {
          "type": "object",
          "properties": {
            "response_code": {"type": "integer"},
            "num_pending": {"type": "integer"},
            "oscore_option": {"$ref": "#/definitions/hex"}
          }
        }
      }
    },
    "ccp_vector": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "type": {"type": "string"},
        "rssi_dbm": {"type": "integer", "minimum": -120, "maximum": 0},
        "threshold_dbm": {"type": "integer", "minimum": -120, "maximum": 0},
        "expected": {"type": "string"},
        "action": {"type": "string"},
        "current_sf": {"type": "integer", "minimum": 7, "maximum": 12},
        "snr_ema": {"type": "integer", "minimum": -30, "maximum": 30},
        "density": {"type": "integer", "minimum": 0},
        "per": {"type": "number", "minimum": 0, "maximum": 100},
        "load_factor": {"type": "number", "minimum": 0, "maximum": 1},
        "expected_sf": {"type": "integer", "minimum": 7, "maximum": 12},
        "reason": {"type": "string"},
        "snr_samples": {
          "type": "array",
          "items": {"type": "integer", "minimum": -30, "maximum": 30}
        },
        "expected_ema": {"type": "integer"},
        "expected_sf_from_ema": {"type": "integer", "minimum": 7, "maximum": 12},
        "eui64_hex": {"$ref": "#/definitions/hex"},
        "num_slots": {"type": "integer", "minimum": 1},
        "expected_slot": {"type": "integer"},
        "slot_ms": {"type": "integer"},
        "guard_ms": {"type": "integer"},
        "drift_ppm": {"type": "integer"},
        "superframe_ms": {"type": "integer"},
        "beacon_nominal_ms": {"type": "integer"},
        "observed_ms": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "expected_ppm": {"type": "integer"},
        "slot_adjust_ticks": {"type": "integer"},
        "current_sfn": {"type": "integer", "minimum": 0},
        "last_sfn": {"type": "integer", "minimum": 0},
        "guard_ppm": {"type": "integer"},
        "version": {"type": "integer", "minimum": 0},
        "alternate_version": {"type": "integer", "minimum": 0},
        "util": {"type": "number", "minimum": 0, "maximum": 1},
        "queue_peak": {"type": "integer"},
        "etx": {"type": "number"},
        "score": {"type": "number"},
        "expected_density": {"type": "integer", "minimum": 0},
        "hash_32_example": {"$ref": "#/definitions/hex"},
        "busy_time_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "expected_score": {"type": "number"},
        "channel_scores": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 100}
        },
        "threshold": {"type": "number", "minimum": 0, "maximum": 1},
        "cca_result": {"type": "string"},
