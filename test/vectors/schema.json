{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LICHEN test vector file",
  "description": "Envelope shared by all LICHEN vector files. Each file holds a list of vectors of one kind; see the per-vector definitions.",
  "type": "object",
  "required": ["format_version", "description", "vectors"],
  "properties": {
    "format_version": {"type": "integer", "const": 1},
    "description": {"type": "string"},
    "vectors": {
      "type": "array",
      "items": {
        "oneOf": [
          {"$ref": "#/definitions/schc_vector"},
          {"$ref": "#/definitions/frame_vector"},
          {"$ref": "#/definitions/meshtastic_app_compat_vector"},
          {"$ref": "#/definitions/meshcore_app_compat_vector"}
        ]
      }
    }
  },
  "definitions": {
    "hex": {
      "type": "string",
      "pattern": "^([0-9a-f][0-9a-f])*$",
      "description": "Lowercase hex-encoded byte string (may be empty)."
    },
    "schc_vector": {
      "type": "object",
      "required": ["name", "rule_id", "packet", "compressed"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "expect": {
                "required": ["response_prefix"]
              }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["response_len"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "rule_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "description": {"type": "string"},
        "packet": {"$ref": "#/definitions/hex",
          "description": "Full uncompressed IPv6 datagram."},
        "compressed": {"$ref": "#/definitions/hex",
          "description": "SCHC output: leading rule-id byte + residue + tail."}
      }
    },
    "frame_vector": {
      "type": "object",
      "required": ["name", "fields", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "required": ["epoch", "seqnum", "dst_addr", "payload", "mic",
                       "addr_mode", "mic_length", "signature_present", "encrypted"],
          "properties": {
            "epoch": {"type": "integer", "minimum": 0, "maximum": 255},
            "seqnum": {"type": "integer", "minimum": 0, "maximum": 65535},
            "dst_addr": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"},
            "mic": {"$ref": "#/definitions/hex"},
            "addr_mode": {"type": "integer", "minimum": 0, "maximum": 3},
            "mic_length": {"type": "integer", "minimum": 0, "maximum": 1},
            "signature_present": {"type": "boolean"},
            "encrypted": {"type": "boolean"}
          }
        },
        "encoded": {"$ref": "#/definitions/hex",
          "description": "On-air frame bytes (length-prefixed)."}
      }
    },
    "meshtastic_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "protobuf",
        "message",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"message": {"const": "want_config_id"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_sequence", "terminal_from_radio"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"enum": ["invalid_stream_framing", "oversized"]}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["reject"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.PRIVATE_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["unsupported", "side_effect"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.ROUTING_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["delivery_status"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["packet.TEXT_MESSAGE_APP", "packet.ROUTING_APP"]}
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_id"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "FromNum"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["byte_order", "read_until_empty"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "Empty"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["queue_drained", "no_from_num_increment"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["protobufs", "firmware", "python", "android", "apple"],
          "additionalProperties": false,
          "properties": {
            "protobufs": {"type": "string"},
            "firmware": {"type": "string"},
            "python": {"type": "string"},
            "android": {"type": "string"},
            "apple": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing", "reject_prefix_hex"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string"},
            "framing": {"type": "string"},
            "reject_prefix_hex": {"$ref": "#/definitions/hex"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "protobuf": {"type": "string", "enum": ["ToRadio", "FromRadio", "FromNum", "Empty"]},
        "message": {"type": "string"},
        "encoded": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "properties": {
            "delivery_status": {"type": "string", "enum": ["ack", "nak"]},
            "from_radio_id": {"type": "integer", "minimum": 1},
            "from_radio_sequence": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            },
            "max_to_radio_bytes": {"type": "integer", "minimum": 1},
            "must_not_require_before_sync": {"type": "boolean"},
            "byte_order": {"type": "string", "enum": ["little-endian"]},
            "no_from_num_increment": {"type": "boolean"},
            "queue_side_effect": {"type": "string"},
            "queue_drained": {"type": "boolean"},
            "reason": {"type": "string"},
            "read_until_empty": {"type": "boolean"},
            "response_to": {"type": "string"},
            "reject": {"type": "boolean"},
            "response": {"type": "string"},
            "side_effect": {"type": "string"},
            "terminal_from_radio": {"$ref": "#/definitions/hex"},
            "unsupported": {"type": "boolean"}
          }
        }
      }
    },
    "meshcore_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "frame",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["firmware", "flutter", "python", "cli", "js"],
          "additionalProperties": false,
          "properties": {
            "firmware": {"type": "string"},
            "flutter": {"type": "string"},
            "python": {"type": "string"},
            "cli": {"type": "string"},
            "js": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string", "enum": ["ble-nus", "serial"]},
            "framing": {"type": "string"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "frame": {"type": "string", "enum": ["command", "response", "push", "serial"]},
        "encoded": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "adapter_test": {"type": "boolean"},
            "drift_note": {"type": "string"},
            "emitted_by": {"type": "string"},
            "inner_frame": {"$ref": "#/definitions/hex"},
            "preceded_by": {"type": "string"},
            "response_len": {"type": "integer", "minimum": 0},
            "response_prefix": {"$ref": "#/definitions/hex"},
            "response_to": {"type": "string"},
            "responses": {
              "type": "array",
              "items": {"$ref": "#/definitions/hex"},
              "minItems": 1
            }
          }
        }
      }
    }
  }
}
