{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LICHEN test vector file",
  "description": "Envelope shared by all LICHEN vector files. Each file holds a list of vectors of one kind; see the per-vector definitions.",
  "oneOf": [
    {"$ref": "#/$defs/dao_origin_signature_document"},
    {"$ref": "#/$defs/legacy_document"}
  ],
  "definitions": {
    "hex": {
      "type": "string",
      "pattern": "^([0-9a-f][0-9a-f])*$",
      "description": "Lowercase hex-encoded byte string (may be empty)."
    },
    "schc_vector": {
      "type": "object",
      "required": ["name", "rule_id", "packet", "compressed"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "expect": {
                "required": ["response_prefix"]
              }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["response_len"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "rule_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "description": {"type": "string"},
        "packet": {"$ref": "#/definitions/hex",
          "description": "Full uncompressed IPv6 datagram."},
        "compressed": {"$ref": "#/definitions/hex",
          "description": "SCHC output: leading rule-id byte + residue + tail."}
      }
    },
    "announce_coords_vector": {
      "type": "object",
      "required": ["name", "latitude_degrees", "longitude_degrees", "latitude_e7", "longitude_e7", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "latitude_degrees": {"type": "number", "minimum": -90, "maximum": 90},
        "longitude_degrees": {"type": "number", "minimum": -180, "maximum": 180},
        "latitude_e7": {"type": "integer", "minimum": -900000000, "maximum": 900000000},
        "longitude_e7": {"type": "integer", "minimum": -1800000000, "maximum": 1800000000},
        "encoded": {
          "type": "string",
          "pattern": "^01[0-9a-f]{16}$",
          "description": "Announce app_data Type=0x01 bytes: type + signed big-endian lat_e7 + signed big-endian lon_e7."
        }
      }
    },
    "l2_payload_vector": {
      "type": "object",
      "required": ["name", "dispatch", "kind", "body", "wrapped"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "dispatch": {"type": "integer", "minimum": 0, "maximum": 255},
        "kind": {"type": "string", "enum": ["schc", "routing", "unknown"]},
        "body": {"$ref": "#/definitions/hex",
          "description": "Payload bytes after the dispatch byte."},
        "wrapped": {"$ref": "#/definitions/hex",
          "description": "Authenticated link inner payload: dispatch byte + body."}
      }
    },
    "frame_vector": {
      "type": "object",
      "required": ["name", "fields", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "required": ["epoch", "seqnum", "dst_addr", "payload", "mic",
                       "addr_mode", "mic_length", "signature_present", "encrypted"],
          "properties": {
            "epoch": {"type": "integer", "minimum": 0, "maximum": 255},
            "seqnum": {"type": "integer", "minimum": 0, "maximum": 65535},
            "dst_addr": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"},
            "mic": {"$ref": "#/definitions/hex"},
            "addr_mode": {"type": "integer", "minimum": 0, "maximum": 3},
            "mic_length": {"type": "integer", "minimum": 0, "maximum": 1},
            "signature_present": {"type": "boolean"},
            "encrypted": {"type": "boolean"}
          }
        },
        "encoded": {"$ref": "#/definitions/hex",
          "description": "On-air frame bytes (length-prefixed)."}
      }
    },
    "meshtastic_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "protobuf",
        "message",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"message": {"const": "want_config_id"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_sequence", "terminal_from_radio"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "enum": [
                  "want_config_stage_69420",
                  "legacy_full_sync_unknown_nonce"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": [
                  "from_radio_sequence",
                  "config_sections",
                  "terminal_from_radio"
                ]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"enum": ["invalid_stream_framing", "oversized"]}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["reject"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.PRIVATE_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["unsupported", "side_effect"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.ROUTING_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["delivery_status"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["packet.TEXT_MESSAGE_APP", "packet.ROUTING_APP"]}
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_id"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["config", "moduleConfig", "region_presets"]}
            }
          },
          "then": {
            "required": ["payload"],
            "properties": {
              "expect": {
                "required": ["from_radio_field"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "FromNum"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["byte_order", "read_until_empty"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "Empty"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["queue_drained", "no_from_num_increment"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["protobufs", "firmware", "python", "android", "apple"],
          "additionalProperties": false,
          "properties": {
            "protobufs": {"type": "string"},
            "firmware": {"type": "string"},
            "python": {"type": "string"},
            "android": {"type": "string"},
            "apple": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing", "reject_prefix_hex"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string"},
            "framing": {"type": "string"},
            "reject_prefix_hex": {"$ref": "#/definitions/hex"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "protobuf": {"type": "string", "enum": ["ToRadio", "FromRadio", "FromNum", "Empty"]},
        "message": {"type": "string"},
        "encoded": {"$ref": "#/definitions/hex"},
        "payload": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "properties": {
            "delivery_status": {"type": "string", "enum": ["ack", "nak"]},
            "from_radio_field": {"type": "integer", "minimum": 1},
            "from_radio_id": {"type": "integer", "minimum": 1},
            "from_radio_sequence": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            },
            "config_sections": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["section", "oneof_field", "payload", "fields"],
                "additionalProperties": false,
                "properties": {
                  "section": {"type": "string"},
                  "oneof_field": {"type": "integer", "minimum": 1},
                  "payload": {"$ref": "#/definitions/hex"},
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["field", "wire_type", "value"],
                      "additionalProperties": false,
                      "properties": {
                        "field": {"type": "integer", "minimum": 1},
                        "wire_type": {"type": "string", "enum": ["varint"]},
                        "value": {"type": "integer", "minimum": 0}
                      }
                    },
                    "minItems": 1
                  }
                }
              },
              "minItems": 1
            },
            "config_section": {
              "type": "object",
              "required": ["section", "oneof_field", "payload", "fields"],
              "additionalProperties": false,
              "properties": {
                "section": {"type": "string"},
                "oneof_field": {"type": "integer", "minimum": 1},
                "payload": {"$ref": "#/definitions/hex"},
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["field", "wire_type", "value"],
                    "additionalProperties": false,
                    "properties": {
                      "field": {"type": "integer", "minimum": 1},
                      "wire_type": {"type": "string", "enum": ["varint"]},
                      "value": {"type": "integer", "minimum": 0}
                    }
                  },
                  "minItems": 1
                }
              }
            },
            "max_to_radio_bytes": {"type": "integer", "minimum": 1},
            "must_not_require_before_sync": {"type": "boolean"},
            "byte_order": {"type": "string", "enum": ["little-endian"]},
            "no_from_num_increment": {"type": "boolean"},
            "queue_side_effect": {"type": "string"},
            "queue_drained": {"type": "boolean"},
            "reason": {"type": "string"},
            "read_until_empty": {"type": "boolean"},
            "response_to": {"type": "string"},
            "reject": {"type": "boolean"},
            "response": {"type": "string"},
            "side_effect": {"type": "string"},
            "terminal_from_radio": {"$ref": "#/definitions/hex"},
            "unsupported": {"type": "boolean"}
          }
        }
      }
    },
    "meshcore_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "frame",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["firmware", "flutter", "python", "cli", "js"],
          "additionalProperties": false,
          "properties": {
            "firmware": {"type": "string"},
            "flutter": {"type": "string"},
            "python": {"type": "string"},
            "cli": {"type": "string"},
            "js": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string", "enum": ["ble-nus", "serial"]},
            "framing": {"type": "string"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "frame": {"type": "string", "enum": ["command", "response", "push", "serial"]},
        "encoded": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "adapter_test": {"type": "boolean"},
            "compat_store": {"type": "string"},
            "drift_note": {"type": "string"},
            "emitted_by": {"type": "string"},
            "fixture": {"type": "string"},
            "inner_frame": {"$ref": "#/definitions/hex"},
            "preceded_by": {"type": "string"},
            "response_len": {"type": "integer", "minimum": 0},
            "response_prefix": {"$ref": "#/definitions/hex"},
            "response_to": {"type": "string"},
            "responses": {
              "type": "array",
              "items": {"$ref": "#/definitions/hex"},
              "minItems": 1
            }
          }
        }
      }
    },
    "oscore_vector": {
      "type": "object",
      "required": ["name", "type"],
      "description": "OSCORE (RFC 8613) test vector for key derivation, request/response protection, replay detection, or invalid input.",
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["key_derivation", "request_protection", "response_protection", "roundtrip", "replay", "invalid"]
        },
        "description": {"type": "string"},
        "master_secret": {"$ref": "#/definitions/hex", "description": "16-byte master secret (AES-128)"},
        "master_salt": {
          "oneOf": [{"$ref": "#/definitions/hex"}, {"type": "null"}],
          "description": "Optional master salt (up to 8 bytes)"
        },
        "sender_id": {"$ref": "#/definitions/hex", "description": "Sender ID (up to 7 bytes)"},
        "recipient_id": {"$ref": "#/definitions/hex", "description": "Recipient ID (up to 7 bytes)"},
        "id_context": {
          "oneOf": [{"$ref": "#/definitions/hex"}, {"type": "null"}],
          "description": "Optional ID Context"
        },
        "algorithm": {
          "type": "integer",
          "description": "COSE algorithm ID (10 = AES-CCM-16-64-128)"
        },
        "sender_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sender sequence number for protection"
        },
        "request_piv": {
          "$ref": "#/definitions/hex",
          "description": "Request Partial IV (for response protection)"
        },
        "request_kid": {
          "$ref": "#/definitions/hex",
          "description": "Request KID (for response AAD)"
        },
        "plaintext": {
          "type": "object",
          "description": "Plaintext CoAP message components",
          "properties": {
            "code": {"type": "integer", "minimum": 0, "maximum": 255},
            "options": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"}
          }
        },
        "ciphertext": {"$ref": "#/definitions/hex"},
        "highest_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Highest seen sequence number (replay tests)"
        },
        "window_bits": {
          "type": "integer",
          "minimum": 0,
          "description": "Replay window bitmask (replay tests)"
        },
        "test_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sequence number to test (replay tests)"
        },
        "expected": {
          "type": "object",
          "description": "Expected results",
          "properties": {
            "sender_key": {"$ref": "#/definitions/hex"},
            "recipient_key": {"$ref": "#/definitions/hex"},
            "common_iv": {"$ref": "#/definitions/hex"},
            "oscore_option": {"$ref": "#/definitions/hex"},
            "ciphertext": {"$ref": "#/definitions/hex"},
            "is_replay": {"type": "boolean"},
            "new_highest": {"type": "integer"},
            "new_window": {"type": "integer"}
          }
        },
        "expected_error": {
          "type": "string",
          "enum": ["invalid_param", "decrypt_failed", "replay", "seq_exhausted"]
        }
      }
    },
    "rpl_messages_vector": {
      "type": "object",
      "required": ["name", "type", "encoded"],
      "description": "RPL control message (RFC 6550) parse/generate vector.",
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["dio", "dao", "dao_ack", "dis", "option", "dio_with_options", "dao_with_options", "option_chain"],
          "description": "Message or option type being tested"
        },
        "option_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "RPL option type (for type=option vectors)"
        },
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "description": "Decoded message fields (structure varies by type)"
        },
        "options": {
          "type": "array",
          "description": "Option chain (for type=option_chain vectors)",
          "items": {"type": "object"}
        },
        "encoded": {
          "$ref": "#/definitions/hex",
          "description": "Encoded message bytes (excluding ICMPv6 header)"
        }
      }
    },
    "dao_origin_signature_vector": {
      "type": "object",
      "required": [
        "name", "description", "coverage", "signing_seed", "public_key",
        "source_ipv6", "effective_instance_id", "active_dodag_id", "effective_dodag_id",
        "sequence", "unsigned_dao",
        "digest", "signature_option", "option_offset", "signed_dao",
        "key_available", "prior", "expected"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"expected": {"properties": {"accepted": {"const": true}}}}},
          "then": {
            "properties": {
              "expected": {
                "properties": {
                  "envelope_valid": {"const": true},
                  "signature_valid": {"const": true},
                  "reason": {"enum": ["accepted", "idempotent", "reconciled"]}
                }
              },
              "key_available": {"const": true}
            }
          }
        },
        {
          "if": {"properties": {"coverage": {"const": "identical_retransmission"}}},
          "then": {
            "properties": {
              "prior": {"$ref": "#/definitions/dao_origin_prior"},
              "expected": {
                "properties": {
                  "accepted": {"const": true},
                  "route_changed": {"const": false},
                  "replay_persisted": {"const": false},
                  "reason": {"const": "idempotent"}
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"expected": {"properties": {"reason": {"const": "accepted"}}}}},
          "then": {"properties": {"expected": {"properties": {
            "route_changed": {"const": true}, "replay_persisted": {"const": true}
          }}}}
        },
        {
          "if": {"properties": {"expected": {"properties": {"reason": {"const": "reconciled"}}}}},
          "then": {
            "properties": {
              "prior": {
                "allOf": [
                  {"$ref": "#/definitions/dao_origin_prior"},
                  {"properties": {"route_present": {"const": false}}}
                ]
              },
              "expected": {"properties": {
                "route_changed": {"const": true}, "replay_persisted": {"const": false}
              }}
            }
          }
        },
        {
          "if": {
            "properties": {
              "coverage": {
                "enum": [
                  "same_sequence_conflict", "lower_replay", "cross_prefix_equal",
                  "cross_prefix_lower", "replay_target_mismatch",
                  "replay_malformed_semantics", "replay_non128_target", "replay_structural",
                  "identical_retransmission", "reconcile_after_crash"
                ]
              }
            }
          },
          "then": {"properties": {"prior": {"$ref": "#/definitions/dao_origin_prior"}}}
        },
        {
          "if": {"properties": {"expected": {"properties": {"accepted": {"const": false}}}}},
          "then": {"properties": {"expected": {"properties": {
            "route_changed": {"const": false}, "replay_persisted": {"const": false}
          }}}}
        }
      ],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "coverage": {
          "type": "string",
          "enum": [
            "d1", "d0_effective_dodag", "withdrawal",
            "high_byte_sequence", "source_mutation", "dodag_mutation",
            "instance_mutation", "dao_sequence_mutation", "target_mutation",
            "parent_mutation", "path_sequence_mutation", "lifetime_mutation",
            "order_mutation", "signature_mutation", "duplicate_option",
            "nonterminal_option", "unknown_key", "iid_mismatch",
            "identical_retransmission", "same_sequence_conflict", "lower_replay",
            "unknown_option", "d0_instance_mismatch", "d0_dodag_mismatch",
            "target_mismatch", "cross_prefix_equal", "cross_prefix_lower",
            "reconcile_after_crash", "d1_active_dodag_mismatch", "missing_signature",
            "zero_sequence", "bad_option_length", "truncated_option", "malformed_base",
            "truncated_dodag", "unsupported_flags", "nonzero_reserved", "missing_target",
            "missing_transit", "duplicate_target", "inconsistent_transit_sequence",
            "inconsistent_transit_lifetime", "unsupported_transit_e", "replay_target_mismatch",
            "replay_malformed_semantics", "replay_non128_target", "replay_structural",
            "fresh_cross_prefix_target", "multiple_distinct_targets",
            "context_malformed_option"
          ]
        },
        "signing_seed": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "public_key": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_ipv6": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "effective_instance_id": {"type": "integer", "minimum": 0, "maximum": 127},
        "active_dodag_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "effective_dodag_id": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "sequence": {"type": "integer", "minimum": 0, "maximum": 18446744073709551615},
        "unsigned_dao": {"$ref": "#/definitions/hex"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{128}$"},
        "signature_option": {"type": "string", "pattern": "^12[0-9a-f]{114}$"},
        "option_offset": {"type": "integer", "minimum": 0},
        "signed_dao": {"$ref": "#/definitions/hex"},
        "key_available": {"type": "boolean"},
        "prior": {
          "oneOf": [
            {"$ref": "#/definitions/dao_origin_prior"},
            {"type": "null"}
          ]
        },
        "expected": {
          "type": "object",
          "required": [
            "accepted", "route_changed", "replay_persisted", "envelope_valid",
            "signature_valid", "reason", "decision_stage"
          ],
          "additionalProperties": false,
          "properties": {
            "accepted": {"type": "boolean"},
            "route_changed": {"type": "boolean"},
            "replay_persisted": {"type": "boolean"},
            "envelope_valid": {"type": "boolean"},
            "signature_valid": {"type": "boolean"},
            "reason": {
              "type": "string",
              "enum": [
                "accepted", "reconciled", "invalid_signature", "duplicate_option",
                "nonterminal_option", "unknown_key", "iid_mismatch", "idempotent",
                "sequence_conflict", "replay", "instance_mismatch", "dodag_mismatch",
                "target_mismatch", "multiple_target", "non128_target", "unknown_option",
                "missing_signature", "zero_sequence",
                "bad_option_length", "truncated", "malformed_dao", "unsupported_flags",
                "nonzero_reserved", "missing_target", "missing_transit", "duplicate_target",
                "inconsistent_transit", "unsupported_transit_e"
              ]
            },
            "decision_stage": {
              "type": "string",
              "enum": [
                "structural", "context", "identity", "replay", "semantic",
                "persistence", "applied"
              ]
            }
          }
        }
      }
    },
    "dao_origin_prior": {
      "type": "object",
      "required": ["source_ipv6", "sequence", "signed_dao", "route_present"],
      "additionalProperties": false,
      "properties": {
        "source_ipv6": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
        "sequence": {"type": "integer", "minimum": 1, "maximum": 18446744073709551615},
        "signed_dao": {"$ref": "#/definitions/hex"},
        "route_present": {"type": "boolean"}
