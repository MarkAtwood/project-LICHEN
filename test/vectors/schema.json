{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LICHEN test vector file",
  "description": "Combined envelope from parallel worker branches (incl. worker8,worker20,worker23; resolved project-LICHEN-9r55 merge-conflict in worktree-worker20: schema.json) for all LICHEN test vector files. Supports object with format_version enum[1,2] (v2 preferred, const=2 in most files), per-family docs (dedicated ccp15_document, ccp_load_balancing_document, rpl_route_state_document, dao_origin_signature_document etc.), bare array root (for ccp16-desync.json), strict required fields, additionalProperties:false, oneOf/allOf for per-vector variants to enforce independent oracles/test integrity only. See README.md.",
  "oneOf": [
    {
      "type": "object",
      "required": ["format_version", "description", "vectors"],
      "additionalProperties": false,
      "properties": {
        "format_version": {"type": "integer", "enum": [1, 2]},
        "description": {"type": "string"},
        "$schema": {"type": "string"},
        "name": {"type": "string"},
        "spec": {"type": "string"},
        "vector_type": {"type": "string", "enum": ["rpl_route_state", "dao_origin_signature"]},
        "oracle": {"type": "object"},
        "oracle_provenance": {"type": "object"},
        "sequence_relations": {"type": "array"},
        "tx_sequence_transitions": {"type": "array"},
        "route_hop_boundaries": {"type": "array"},
        "vectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              {"$ref": "#/definitions/schc_vector"},
              {"$ref": "#/definitions/schc_fragmentation_vector"},
              {"$ref": "#/definitions/l2_payload_vector"},
              {"$ref": "#/definitions/frame_vector"},
              {"$ref": "#/definitions/announce_coords_vector"},
              {"$ref": "#/definitions/meshtastic_app_compat_vector"},
              {"$ref": "#/definitions/meshcore_app_compat_vector"},
              {"$ref": "#/definitions/oscore_vector"},
              {"$ref": "#/definitions/rpl_messages_vector"},
              {"$ref": "#/definitions/rpl_route_state_vector"},
              {"$ref": "#/definitions/dao_origin_signature_vector"},
              {"$ref": "#/definitions/ccp13_vector"},
              {"$ref": "#/definitions/ccp15_vector"},
              {"$ref": "#/definitions/ccp_vector"},
              {"$ref": "#/definitions/compact_cot_vector"},
              {"$ref": "#/definitions/schnorr48_vector"},
              {"$ref": "#/definitions/hash_32_vector"},
              {"$ref": "#/definitions/ccp_load_balancing_vector"}
            ]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"vector_type": {"const": "dao_origin_signature"}},
            "required": ["vector_type"]
          },
          "then": {
            "required": ["oracle_provenance"]
          }
        },
        {
          "if": {
            "required": ["oracle_provenance"]
          },
          "then": {
            "required": ["vector_type"]
          }
        },
        {
          "if": {
            "properties": {"vector_type": {"const": "rpl_route_state"}},
            "required": ["vector_type"]
          },
          "then": {
            "required": ["oracle", "sequence_relations"]
          }
        }
      ]
    },
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "anyOf": [
          {"$ref": "#/definitions/schc_vector"},
          {"$ref": "#/definitions/schc_fragmentation_vector"},
          {"$ref": "#/definitions/l2_payload_vector"},
          {"$ref": "#/definitions/frame_vector"},
          {"$ref": "#/definitions/announce_coords_vector"},
          {"$ref": "#/definitions/meshtastic_app_compat_vector"},
          {"$ref": "#/definitions/meshcore_app_compat_vector"},
          {"$ref": "#/definitions/oscore_vector"},
          {"$ref": "#/definitions/rpl_messages_vector"},
          {"$ref": "#/definitions/rpl_route_state_vector"},
          {"$ref": "#/definitions/dao_origin_signature_vector"},
          {"$ref": "#/definitions/ccp13_vector"},
          {"$ref": "#/definitions/ccp15_vector"},
          {"$ref": "#/definitions/ccp_vector"},
          {"$ref": "#/definitions/compact_cot_vector"},
          {"$ref": "#/definitions/schnorr48_vector"},
          {"$ref": "#/definitions/hash_32_vector"},
          {"$ref": "#/definitions/ccp_load_balancing_vector"}
        ]
      },
      "description": "v2 bare array root (used by ccp16-desync.json for desync test vectors)"
    }
  ],
  "definitions": {
    "document_base": {
      "type": "object",
      "required": ["format_version", "description", "vectors"],
      "additionalProperties": false,
      "properties": {
        "format_version": {"type": "integer", "enum": [1, 2]},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "spec": {"type": "string"},
        "$schema": {"type": "string"},
        "vectors": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "schc_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/schc_vector"}
            }
          }
        }
      ]
    },
    "l2_payload_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/l2_payload_vector"}
            }
          }
        }
      ]
    },
    "link_frame_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/frame_vector"}
            }
          }
        }
      ]
    },
    "announce_coords_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/announce_coords_vector"}
            }
          }
        }
      ]
    },
    "meshtastic_app_compat_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/meshtastic_app_compat_vector"}
            }
          }
        }
      ]
    },
    "meshcore_app_compat_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/meshcore_app_compat_vector"}
            }
          }
        }
      ]
    },
    "oscore_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/oscore_vector"}
            }
          }
        }
      ]
    },
    "rpl_messages_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/rpl_messages_vector"}
            }
          }
        }
      ]
    },
    "ccp15_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/ccp15_vector"}
            }
          }
        }
      ]
    },
    "ccp_load_balancing_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/ccp_load_balancing_vector"}
            }
          }
        }
      ]
    },
    "compact_cot_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/compact_cot_vector"}
            }
          }
        }
      ]
    },
    "schnorr48_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/schnorr48_vector"}
            }
          }
        }
      ]
    },
    "hex": {
      "type": "string",
      "pattern": "^([0-9a-f][0-9a-f])*$",
      "description": "Lowercase hex-encoded byte string (may be empty)."
    },
    "schc_vector": {
      "type": "object",
      "required": ["name", "rule_id", "packet", "compressed"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "expect": {
                "required": ["response_prefix"]
              }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["response_len"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "rule_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "description": {"type": "string"},
        "packet": {"$ref": "#/definitions/hex",
          "description": "Full uncompressed IPv6 datagram."},
        "compressed": {"$ref": "#/definitions/hex",
          "description": "SCHC output: leading rule-id byte + residue + tail."}
      }
    },
    "byte_part": {
      "oneOf": [
        {"$ref": "#/definitions/hex"},
        {
          "type": "object",
          "required": ["repeat_byte", "count"],
          "additionalProperties": false,
          "properties": {
            "repeat_byte": {"type": "string", "pattern": "^[0-9a-f]{2}$"},
            "count": {"type": "integer", "minimum": 1, "maximum": 23563}
          }
        }
      ]
    },
    "byte_value": {
      "oneOf": [
        {"$ref": "#/definitions/hex"},
        {
          "type": "object",
          "required": ["parts"],
          "additionalProperties": false,
          "properties": {
            "parts": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/definitions/byte_part"}
            }
          }
        }
      ]
    },
    "fragmentation_fragment": {
      "type": "object",
      "required": ["name", "kind", "window", "fcn", "tile_ordinal", "wire"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "kind": {"type": "string", "enum": ["regular", "all0", "all1"]},
        "window": {"type": "integer", "minimum": 0, "maximum": 1},
        "fcn": {"type": "integer", "minimum": 0, "maximum": 63},
        "tile_ordinal": {"type": "integer", "minimum": 0, "maximum": 125},
        "wire": {"$ref": "#/definitions/byte_value"}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "regular"}}}, "then": {"properties": {"fcn": {"minimum": 1, "maximum": 62}}}},
        {"if": {"properties": {"kind": {"const": "all0"}}}, "then": {"properties": {"window": {"const": 0}, "fcn": {"const": 0}}}},
        {"if": {"properties": {"kind": {"const": "all1"}}}, "then": {"properties": {"fcn": {"const": 63}}}}
      ]
    },
    "fragmentation_controls": {
      "type": "object",
      "required": ["ack_success_w0", "ack_success_w1", "ack_req_w0", "ack_req_w1", "sender_abort", "receiver_abort"],
      "additionalProperties": false,
      "properties": {
        "ack_success_w0": {"$ref": "#/definitions/hex"},
        "ack_success_w1": {"$ref": "#/definitions/hex"},
        "ack_req_w0": {"$ref": "#/definitions/hex"},
        "ack_req_w1": {"$ref": "#/definitions/hex"},
        "sender_abort": {"$ref": "#/definitions/hex"},
        "receiver_abort": {"$ref": "#/definitions/hex"}
      }
    },
    "fragmentation_loss": {
      "type": "object",
      "required": ["drop_fragment", "ack_failure", "ack_req", "ack_success"],
      "additionalProperties": false,
      "properties": {
        "drop_fragment": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "ack_failure": {"$ref": "#/definitions/byte_value"},
        "retransmission": {"$ref": "#/definitions/byte_value"},
        "ack_req": {"$ref": "#/definitions/byte_value"},
        "ack_success": {"$ref": "#/definitions/byte_value"},
        "corrupt_all1": {"$ref": "#/definitions/byte_value"},
        "rcs_failure_ack": {"$ref": "#/definitions/byte_value"},
        "next_sender_message": {"$ref": "#/definitions/byte_value"}
      }
    },
    "schc_fragmentation_vector": {
      "type": "object",
      "required": ["name", "category", "provenance"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "category": {"type": "string", "enum": ["recovery", "window_transition", "controls", "retry_exhaustion", "capacity", "malformed"]},
        "provenance": {"type": "string", "minLength": 1},
        "rule_id": {"type": "integer", "enum": [120, 121]},
        "packet": {"$ref": "#/definitions/byte_value"},
        "packet_length": {"type": "integer", "minimum": 1, "maximum": 23563},
        "packet_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "rcs": {"type": "string", "pattern": "^[0-9a-f]{8}$"},
        "fragment_count": {"type": "integer", "minimum": 0, "maximum": 126},
        "fragments": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/fragmentation_fragment"}},
        "loss": {"$ref": "#/definitions/fragmentation_loss"},
        "controls": {
          "type": "object",
          "required": ["rule_78", "rule_79"],
          "additionalProperties": false,
          "properties": {
            "rule_78": {"$ref": "#/definitions/fragmentation_controls"},
            "rule_79": {"$ref": "#/definitions/fragmentation_controls"}
          }
        },
        "attempts_before": {"type": "integer", "const": 4},
        "trigger": {"$ref": "#/definitions/byte_value"},
        "expected_message": {"$ref": "#/definitions/byte_value"},
        "expect_status": {"type": "string", "enum": ["ok", "packet_too_large", "aborted"]},
        "wire": {"$ref": "#/definitions/byte_value"},
        "assigned_fcns": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 0, "maximum": 63}},
        "expect_error": {"type": "string", "pattern": "^[a-z0-9_]+$"}
      },
      "allOf": [
        {"if": {"properties": {"category": {"enum": ["recovery", "window_transition"]}}}, "then": {"required": ["rule_id", "packet", "packet_length", "packet_sha256", "rcs", "fragments", "loss"], "not": {"anyOf": [{"required": ["controls"]}, {"required": ["attempts_before"]}, {"required": ["trigger"]}, {"required": ["expected_message"]}, {"required": ["expect_status"]}, {"required": ["wire"]}, {"required": ["assigned_fcns"]}, {"required": ["expect_error"]}]}}},
        {"if": {"properties": {"category": {"const": "controls"}}}, "then": {"required": ["controls"], "not": {"anyOf": [{"required": ["rule_id"]}, {"required": ["packet"]}, {"required": ["packet_length"]}, {"required": ["packet_sha256"]}, {"required": ["rcs"]}, {"required": ["fragment_count"]}, {"required": ["fragments"]}, {"required": ["loss"]}, {"required": ["attempts_before"]}, {"required": ["trigger"]}, {"required": ["expected_message"]}, {"required": ["expect_status"]}, {"required": ["wire"]}, {"required": ["assigned_fcns"]}, {"required": ["expect_error"]}]}}},
        {"if": {"properties": {"category": {"const": "retry_exhaustion"}}}, "then": {"required": ["rule_id", "attempts_before", "trigger", "expected_message", "expect_status"], "not": {"anyOf": [{"required": ["packet"]}, {"required": ["packet_length"]}, {"required": ["packet_sha256"]}, {"required": ["rcs"]}, {"required": ["fragment_count"]}, {"required": ["fragments"]}, {"required": ["loss"]}, {"required": ["controls"]}, {"required": ["wire"]}, {"required": ["assigned_fcns"]}, {"required": ["expect_error"]}]}}},
        {"if": {"properties": {"category": {"const": "capacity"}}}, "then": {"required": ["packet", "packet_length", "packet_sha256", "fragment_count", "expect_status"], "not": {"anyOf": [{"required": ["rule_id"]}, {"required": ["fragments"]}, {"required": ["loss"]}, {"required": ["controls"]}, {"required": ["attempts_before"]}, {"required": ["trigger"]}, {"required": ["expected_message"]}, {"required": ["wire"]}, {"required": ["assigned_fcns"]}, {"required": ["expect_error"]}]}}},
        {"if": {"properties": {"category": {"const": "malformed"}}}, "then": {"required": ["wire", "expect_error"], "not": {"anyOf": [{"required": ["rule_id"]}, {"required": ["packet"]}, {"required": ["packet_length"]}, {"required": ["packet_sha256"]}, {"required": ["rcs"]}, {"required": ["fragment_count"]}, {"required": ["fragments"]}, {"required": ["loss"]}, {"required": ["controls"]}, {"required": ["attempts_before"]}, {"required": ["trigger"]}, {"required": ["expected_message"]}, {"required": ["expect_status"]}]}}}
      ]
    },
    "announce_coords_vector": {
      "type": "object",
      "required": ["name", "latitude_degrees", "longitude_degrees", "latitude_e7", "longitude_e7", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "latitude_degrees": {"type": "number", "minimum": -90, "maximum": 90},
        "longitude_degrees": {"type": "number", "minimum": -180, "maximum": 180},
        "latitude_e7": {"type": "integer", "minimum": -900000000, "maximum": 900000000},
        "longitude_e7": {"type": "integer", "minimum": -1800000000, "maximum": 1800000000},
        "encoded": {
          "type": "string",
          "pattern": "^01[0-9a-f]{16}$",
          "description": "Announce app_data Type=0x01 bytes: type + signed big-endian lat_e7 + signed big-endian lon_e7."
        }
      }
    },
    "l2_payload_vector": {
      "type": "object",
      "required": ["name", "dispatch", "kind", "body", "wrapped"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "dispatch": {"type": "integer", "minimum": 0, "maximum": 255},
        "kind": {"type": "string", "enum": ["schc", "routing", "unknown"]},
        "body": {"$ref": "#/definitions/hex",
          "description": "Payload bytes after the dispatch byte."},
        "wrapped": {"$ref": "#/definitions/hex",
          "description": "Authenticated link inner payload: dispatch byte + body."}
      }
    },
    "frame_vector": {
      "type": "object",
      "required": ["name", "fields", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "additionalProperties": false,
          "required": ["epoch", "seqnum", "dst_addr", "payload", "mic",
                       "addr_mode", "mic_length", "signature_present", "encrypted"],
          "properties": {
            "epoch": {"type": "integer", "minimum": 0, "maximum": 255},
            "seqnum": {"type": "integer", "minimum": 0, "maximum": 65535},
            "dst_addr": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"},
            "mic": {"$ref": "#/definitions/hex"},
            "addr_mode": {"type": "integer", "minimum": 0, "maximum": 3},
            "mic_length": {"type": "integer", "minimum": 0, "maximum": 1},
            "signature_present": {"type": "boolean"},
            "encrypted": {"type": "boolean"}
          }
        },
        "encoded": {"$ref": "#/definitions/hex",
          "description": "On-air frame bytes (length-prefixed)."},
        "expect": {
          "type": "object",
          "required": ["error"],
          "additionalProperties": false,
          "properties": {"error": {"type": "string"}}
        }
      }
    },
    "meshtastic_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "protobuf",
        "message",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"message": {"const": "want_config_id"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_sequence", "terminal_from_radio"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
                "name": {
                  "enum": [
                    "want_config_stage_69420",
                    "legacy_full_sync_unknown_nonce"
                  ]
                }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": [
                  "from_radio_sequence",
                  "config_sections",
                  "terminal_from_radio"
                ]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"enum": ["invalid_stream_framing", "oversized"]}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["reject"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.PRIVATE_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["unsupported", "side_effect"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.ROUTING_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["delivery_status"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["packet.TEXT_MESSAGE_APP", "packet.ROUTING_APP"]}
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_id"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["config", "moduleConfig", "region_presets"]}
            }
          },
          "then": {
            "required": ["payload"],
            "properties": {
              "expect": {
                "required": ["from_radio_field"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "FromNum"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["byte_order", "read_until_empty"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "Empty"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["queue_drained", "no_from_num_increment"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["protobufs", "firmware", "python", "android", "apple"],
          "additionalProperties": false,
          "properties": {
            "protobufs": {"type": "string"},
            "firmware": {"type": "string"},
            "python": {"type": "string"},
            "android": {"type": "string"},
            "apple": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing", "reject_prefix_hex"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string"},
            "framing": {"type": "string"},
            "reject_prefix_hex": {"$ref": "#/definitions/hex"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "protobuf": {"type": "string", "enum": ["ToRadio", "FromRadio", "FromNum", "Empty"]},
        "message": {"type": "string"},
        "encoded": {"$ref": "#/definitions/hex"},
        "payload": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "properties": {
            "delivery_status": {"type": "string", "enum": ["ack", "nak"]},
            "from_radio_field": {"type": "integer", "minimum": 1},
            "from_radio_id": {"type": "integer", "minimum": 1},
            "from_radio_sequence": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            },
            "config_sections": {
              "type": "array",
              "items": {
                "type": "object",
