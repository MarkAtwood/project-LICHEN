{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LICHEN test vector file",
  "description": "v2-only strict schemas. All files now use format_version=2 with per-family document defs. Mutually exclusive oneOf branches, minItems:1, additionalProperties:false enforce one vector family per file. ccp13, ccp15, ccp16 and ccp_load_balancing have dedicated strict defs. No v1 legacy support remains.",
  "oneOf": [
    {"$ref": "#/definitions/schc_document"},
    {"$ref": "#/definitions/l2_payload_document"},
    {"$ref": "#/definitions/link_frame_document"},
    {"$ref": "#/definitions/announce_coords_document"},
    {"$ref": "#/definitions/meshtastic_app_compat_document"},
    {"$ref": "#/definitions/meshcore_app_compat_document"},
    {"$ref": "#/definitions/oscore_document"},
    {"$ref": "#/definitions/rpl_messages_document"},
    {"$ref": "#/definitions/compact_cot_document"},
    {"$ref": "#/definitions/schnorr48_document"},
    {"$ref": "#/definitions/ccp_document"},
    {"$ref": "#/definitions/ccp15_document"},
    {"$ref": "#/definitions/ccp_load_balancing_document"},
    {"$ref": "#/definitions/ccp13_document"}
  ],

  "definitions": {
    "document_base": {
      "type": "object",
      "required": ["format_version", "description", "vectors"],
      "additionalProperties": false,
      "properties": {
        "format_version": {"const": 2},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "spec": {"type": "string"},
        "$schema": {"type": "string"},
        "vectors": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "schc_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/schc_vector"}
            }
          }
        }
      ]
    },
    "l2_payload_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/l2_payload_vector"}
            }
          }
        }
      ]
    },
    "link_frame_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/frame_vector"}
            }
          }
        }
      ]
    },
    "announce_coords_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/announce_coords_vector"}
            }
          }
        }
      ]
    },
    "meshtastic_app_compat_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/meshtastic_app_compat_vector"}
            }
          }
        }
      ]
    },
    "meshcore_app_compat_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/meshcore_app_compat_vector"}
            }
          }
        }
      ]
    },
    "oscore_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/oscore_vector"}
            }
          }
        }
      ]
    },
    "rpl_messages_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/rpl_messages_vector"}
            }
          }
        }
      ]
    },
    "compact_cot_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/compact_cot_vector"}
            }
          }
        }
      ]
    },
    "schnorr48_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/schnorr48_vector"}
            }
          }
        }
      ]
    },
    "hex": {
      "type": "string",
      "pattern": "^([0-9a-f][0-9a-f])*$",
      "description": "Lowercase hex-encoded byte string (may be empty)."
    },
    "schc_vector": {
      "type": "object",
      "required": ["name", "rule_id", "packet", "compressed"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "expect": {
                "required": ["response_prefix"]
              }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["response_len"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "rule_id": {"type": "integer", "minimum": 0, "maximum": 255},
        "description": {"type": "string"},
        "packet": {"$ref": "#/definitions/hex",
          "description": "Full uncompressed IPv6 datagram."},
        "compressed": {"$ref": "#/definitions/hex",
          "description": "SCHC output: leading rule-id byte + residue + tail."}
      }
    },
    "announce_coords_vector": {
      "type": "object",
      "required": ["name", "latitude_degrees", "longitude_degrees", "latitude_e7", "longitude_e7", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "latitude_degrees": {"type": "number", "minimum": -90, "maximum": 90},
        "longitude_degrees": {"type": "number", "minimum": -180, "maximum": 180},
        "latitude_e7": {"type": "integer", "minimum": -900000000, "maximum": 900000000},
        "longitude_e7": {"type": "integer", "minimum": -1800000000, "maximum": 1800000000},
        "encoded": {
          "type": "string",
          "pattern": "^01[0-9a-f]{16}$",
          "description": "Announce app_data Type=0x01 bytes: type + signed big-endian lat_e7 + signed big-endian lon_e7."
        }
      }
    },
    "l2_payload_vector": {
      "type": "object",
      "required": ["name", "dispatch", "kind", "body", "wrapped"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "dispatch": {"type": "integer", "minimum": 0, "maximum": 255},
        "kind": {"type": "string", "enum": ["schc", "routing", "unknown"]},
        "body": {"$ref": "#/definitions/hex",
          "description": "Payload bytes after the dispatch byte."},
        "wrapped": {"$ref": "#/definitions/hex",
          "description": "Authenticated link inner payload: dispatch byte + body."}
      }
    },
    "frame_vector": {
      "type": "object",
      "required": ["name", "fields", "encoded"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "required": ["epoch", "seqnum", "dst_addr", "payload", "mic",
                       "addr_mode", "mic_length", "signature_present", "encrypted"],
          "properties": {
            "epoch": {"type": "integer", "minimum": 0, "maximum": 255},
            "seqnum": {"type": "integer", "minimum": 0, "maximum": 65535},
            "dst_addr": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"},
            "mic": {"$ref": "#/definitions/hex"},
            "addr_mode": {"type": "integer", "minimum": 0, "maximum": 3},
            "mic_length": {"type": "integer", "minimum": 0, "maximum": 1},
            "signature_present": {"type": "boolean"},
            "encrypted": {"type": "boolean"}
          }
        },
        "encoded": {"$ref": "#/definitions/hex",
          "description": "On-air frame bytes (length-prefixed)."},
        "expect": {
          "type": "object",
          "required": ["error"],
          "additionalProperties": false,
          "properties": {"error": {"type": "string"}}
        }
      }
    },
    "meshtastic_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "protobuf",
        "message",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {"properties": {"message": {"const": "want_config_id"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_sequence", "terminal_from_radio"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
                "name": {
                  "enum": [
                    "want_config_stage_69420"
                  ]
                }
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": [
                  "from_radio_sequence",
                  "config_sections",
                  "terminal_from_radio"
                ]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"enum": ["invalid_stream_framing", "oversized"]}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["reject"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.PRIVATE_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["unsupported", "side_effect"]
              }
            }
          }
        },
        {
          "if": {"properties": {"message": {"const": "packet.ROUTING_APP"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["delivery_status"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["packet.TEXT_MESSAGE_APP", "packet.ROUTING_APP"]}
            }
          },
          "then": {
            "properties": {
              "expect": {
                "required": ["from_radio_id"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "protobuf": {"const": "FromRadio"},
              "message": {"enum": ["config", "moduleConfig", "region_presets"]}
            }
          },
          "then": {
            "required": ["payload"],
            "properties": {
              "expect": {
                "required": ["from_radio_field"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "FromNum"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["byte_order", "read_until_empty"]
              }
            }
          }
        },
        {
          "if": {"properties": {"protobuf": {"const": "Empty"}}},
          "then": {
            "properties": {
              "expect": {
                "required": ["queue_drained", "no_from_num_increment"]
              }
            }
          }
        }
      ],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["protobufs", "firmware", "python", "android", "apple"],
          "additionalProperties": false,
          "properties": {
            "protobufs": {"type": "string"},
            "firmware": {"type": "string"},
            "python": {"type": "string"},
            "android": {"type": "string"},
            "apple": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing", "reject_prefix_hex"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string"},
            "framing": {"type": "string"},
            "reject_prefix_hex": {"$ref": "#/definitions/hex"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "protobuf": {"type": "string", "enum": ["ToRadio", "FromRadio", "FromNum", "Empty"]},
        "message": {"type": "string"},
        "encoded": {"$ref": "#/definitions/hex"},
        "payload": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "properties": {
            "delivery_status": {"type": "string", "enum": ["ack", "nak"]},
            "from_radio_field": {"type": "integer", "minimum": 1},
            "from_radio_id": {"type": "integer", "minimum": 1},
            "from_radio_sequence": {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            },
            "config_sections": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["section", "oneof_field", "payload", "fields"],
                "additionalProperties": false,
                "properties": {
                  "section": {"type": "string"},
                  "oneof_field": {"type": "integer", "minimum": 1},
                  "payload": {"$ref": "#/definitions/hex"},
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["field", "wire_type", "value"],
                      "additionalProperties": false,
                      "properties": {
                        "field": {"type": "integer", "minimum": 1},
                        "wire_type": {"type": "string", "enum": ["varint"]},
                        "value": {"type": "integer", "minimum": 0}
                      }
                    },
                    "minItems": 1
                  }
                }
              },
              "minItems": 1
            },
            "config_section": {
              "type": "object",
              "required": ["section", "oneof_field", "payload", "fields"],
              "additionalProperties": false,
              "properties": {
                "section": {"type": "string"},
                "oneof_field": {"type": "integer", "minimum": 1},
                "payload": {"$ref": "#/definitions/hex"},
                "fields": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["field", "wire_type", "value"],
                    "additionalProperties": false,
                    "properties": {
                      "field": {"type": "integer", "minimum": 1},
                      "wire_type": {"type": "string", "enum": ["varint"]},
                      "value": {"type": "integer", "minimum": 0}
                    }
                  },
                  "minItems": 1
                }
              }
            },
            "max_to_radio_bytes": {"type": "integer", "minimum": 1},
            "must_not_require_before_sync": {"type": "boolean"},
            "byte_order": {"type": "string", "enum": ["little-endian"]},
            "no_from_num_increment": {"type": "boolean"},
            "queue_side_effect": {"type": "string"},
            "queue_drained": {"type": "boolean"},
            "reason": {"type": "string"},
            "read_until_empty": {"type": "boolean"},
            "response_to": {"type": "string"},
            "reject": {"type": "boolean"},
            "response": {"type": "string"},
            "side_effect": {"type": "string"},
            "terminal_from_radio": {"$ref": "#/definitions/hex"},
            "unsupported": {"type": "boolean"}
          }
        }
      }
    },
    "meshcore_app_compat_vector": {
      "type": "object",
      "required": [
        "name",
        "description",
        "source_baseline",
        "transport",
        "direction",
        "frame",
        "encoded",
        "decoded",
        "expect"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "source_baseline": {
          "type": "object",
          "required": ["firmware", "flutter", "python", "cli", "js"],
          "additionalProperties": false,
          "properties": {
            "firmware": {"type": "string"},
            "flutter": {"type": "string"},
            "python": {"type": "string"},
            "cli": {"type": "string"},
            "js": {"type": "string"}
          }
        },
        "transport": {
          "type": "object",
          "required": ["name", "framing"],
          "additionalProperties": false,
          "properties": {
            "name": {"type": "string", "enum": ["ble-nus", "serial"]},
            "framing": {"type": "string"}
          }
        },
        "direction": {"type": "string", "enum": ["app_to_node", "node_to_app", "exchange"]},
        "frame": {"type": "string", "enum": ["command", "response", "push", "serial"]},
        "encoded": {"$ref": "#/definitions/hex"},
        "decoded": {"type": "object"},
        "expect": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "adapter_test": {"type": "boolean"},
            "compat_store": {"type": "string"},
            "drift_note": {"type": "string"},
            "emitted_by": {"type": "string"},
            "fixture": {"type": "string"},
            "inner_frame": {"$ref": "#/definitions/hex"},
            "preceded_by": {"type": "string"},
            "response_len": {"type": "integer", "minimum": 0},
            "response_prefix": {"$ref": "#/definitions/hex"},
            "response_to": {"type": "string"},
            "responses": {
              "type": "array",
              "items": {"$ref": "#/definitions/hex"},
              "minItems": 1
            }
          }
        }
      }
    },
    "oscore_vector": {
      "type": "object",
      "required": ["name", "type"],
      "description": "OSCORE (RFC 8613) test vector for key derivation, request/response protection, replay detection, or invalid input.",
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["key_derivation", "request_protection", "response_protection", "roundtrip", "replay", "invalid"]
        },
        "description": {"type": "string"},
        "master_secret": {"$ref": "#/definitions/hex", "description": "16-byte master secret (AES-128)"},
        "master_salt": {
          "oneOf": [{"$ref": "#/definitions/hex"}, {"type": "null"}],
          "description": "Optional master salt (up to 8 bytes)"
        },
        "sender_id": {"$ref": "#/definitions/hex", "description": "Sender ID (up to 7 bytes)"},
        "recipient_id": {"$ref": "#/definitions/hex", "description": "Recipient ID (up to 7 bytes)"},
        "id_context": {
          "oneOf": [{"$ref": "#/definitions/hex"}, {"type": "null"}],
          "description": "Optional ID Context"
        },
        "algorithm": {
          "type": "integer",
          "description": "COSE algorithm ID (10 = AES-CCM-16-64-128)"
        },
        "sender_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sender sequence number for protection"
        },
        "request_piv": {
          "$ref": "#/definitions/hex",
          "description": "Request Partial IV (for response protection)"
        },
        "request_kid": {
          "$ref": "#/definitions/hex",
          "description": "Request KID (for response AAD)"
        },
        "plaintext": {
          "type": "object",
          "description": "Plaintext CoAP message components",
          "properties": {
            "code": {"type": "integer", "minimum": 0, "maximum": 255},
            "options": {"$ref": "#/definitions/hex"},
            "payload": {"$ref": "#/definitions/hex"}
          }
        },
        "ciphertext": {"$ref": "#/definitions/hex"},
        "highest_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Highest seen sequence number (replay tests)"
        },
        "window_bits": {
          "type": "integer",
          "minimum": 0,
          "description": "Replay window bitmask (replay tests)"
        },
        "test_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Sequence number to test (replay tests)"
        },
        "expected": {
          "type": "object",
          "description": "Expected results",
          "properties": {
            "sender_key": {"$ref": "#/definitions/hex"},
            "recipient_key": {"$ref": "#/definitions/hex"},
            "common_iv": {"$ref": "#/definitions/hex"},
            "oscore_option": {"$ref": "#/definitions/hex"},
            "ciphertext": {"$ref": "#/definitions/hex"},
            "is_replay": {"type": "boolean"},
            "new_highest": {"type": "integer"},
            "new_window": {"type": "integer"}
          }
        },
        "expected_error": {
          "type": "string",
          "enum": ["invalid_param", "decrypt_failed", "replay", "seq_exhausted"]
        }
      }
    },
    "rpl_messages_vector": {
      "type": "object",
      "required": ["name", "type", "encoded"],
      "additionalProperties": false,
      "description": "RPL control message (RFC 6550) parse/generate vector.",
      "properties": {
        "name": {"type": "string"},
        "type": {
          "type": "string",
          "enum": ["dio", "dao", "dao_ack", "dis", "option", "dio_with_options", "dao_with_options", "option_chain"],
          "description": "Message or option type being tested"
        },
        "option_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "description": "RPL option type (for type=option vectors)"
        },
        "description": {"type": "string"},
        "fields": {
          "type": "object",
          "description": "Decoded message fields (structure varies by type)"
        },
        "options": {
          "type": "array",
          "description": "Option chain (for type=option_chain vectors)",
          "items": {"type": "object"}
        },
        "encoded": {
          "$ref": "#/definitions/hex",
          "description": "Encoded message bytes (excluding ICMPv6 header)"
        }
      }
    },
    "compact_cot_vector": {
      "type": "object",
      "required": ["name", "description", "binary_hex", "decoded_fields"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "binary_hex": {"$ref": "#/definitions/hex"},
        "decoded_fields": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "subtype": {"type": "integer"},
            "subtype_name": {"type": "string"},
            "latitude_microdegrees": {"type": "integer"},
            "longitude_microdegrees": {"type": "integer"},
            "altitude_decimeters": {"type": "integer"},
            "course_centidegrees": {"type": "integer"},
            "speed_cm_s": {"type": "integer"},
            "team": {"type": "integer"},
            "team_name": {"type": "string"},
            "role": {"type": "integer"},
            "expected_hash": {"type": "integer"}
          }
        }
      }
    },
    "schnorr48_vector": {
      "type": "object",
      "required": ["description", "public_key", "message", "signature", "valid"],
      "additionalProperties": false,
      "properties": {
        "description": {"type": "string"},
        "seed": {"$ref": "#/definitions/hex"},
        "private_key": {"$ref": "#/definitions/hex"},
        "public_key": {"$ref": "#/definitions/hex"},
        "message": {"$ref": "#/definitions/hex"},
        "signature": {"$ref": "#/definitions/hex"},
        "valid": {"type": "boolean"}
      }
    },
    "ccp_document": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/definitions/ccp_vector"},
          "description": "v2 array-root support for CCP variants (oneOf with enveloped form)"
        },
        {
          "allOf": [
            {"$ref": "#/definitions/document_base"},
            {
              "properties": {
                "vectors": {
                  "items": {"$ref": "#/definitions/ccp_vector"}
                }
              }
            }
          ]
        }
      ]
    },
    "ccp15_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/ccp_vector"},
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "ccp_load_balancing_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/ccp_vector"},
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "ccp13_document": {
      "allOf": [
        {"$ref": "#/definitions/document_base"},
        {
          "properties": {
            "vectors": {
              "items": {"$ref": "#/definitions/ccp_vector"},
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      ]
