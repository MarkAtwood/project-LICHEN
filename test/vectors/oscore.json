      "name": "roundtrip_request_with_payload",
      "type": "roundtrip",
      "description": "Request round-trip with CoAP POST and payload",
      "master_secret": "deadbeefcafebabedeadbeefcafebabe",
      "master_salt": "0011223344556677",
      "sender_id": "aa",
      "recipient_id": "bb",
      "id_context": null,
      "algorithm": 10,
      "sender_seq": 42,
      "plaintext": {
        "code": 2,
        "options": "",
        "payload": "7b226d657373616765223a2274657374227d"
      }
    },
    {
      "name": "replay_window_accept_new",
      "type": "replay",
      "description": "New sequence number should be accepted",
      "highest_seq": 100,
      "window_bits": 0,
      "test_seq": 101,
      "expected": {
        "is_replay": false,
        "new_highest": 101,
        "new_window": 1
      }
    },
    {
      "name": "replay_window_reject_duplicate",
      "type": "replay",
      "description": "Duplicate sequence number should be rejected",
      "highest_seq": 100,
      "window_bits": 1,
      "test_seq": 100,
      "expected": {
        "is_replay": true
      }
    },
    {
      "name": "replay_window_accept_within_window",
      "type": "replay",
      "description": "Unseen sequence within window should be accepted",
      "highest_seq": 100,
      "window_bits": 1,
      "test_seq": 99,
      "expected": {
        "is_replay": false,
        "new_highest": 100,
        "new_window": 3
      }
    },
    {
      "name": "replay_window_reject_too_old",
      "type": "replay",
      "description": "Sequence number outside window should be rejected",
      "highest_seq": 100,
      "window_bits": 1,
      "test_seq": 50,
      "expected": {
        "is_replay": true
      }
    },
    {
      "name": "replay_window_large_jump",
      "type": "replay",
      "description": "Large jump forward should clear window",
      "highest_seq": 100,
      "window_bits": 4294967295,
      "test_seq": 200,
      "expected": {
        "is_replay": false,
        "new_highest": 200,
        "new_window": 1
      }
    },
    {
      "name": "invalid_id_too_long",
      "type": "invalid",
      "description": "Sender ID exceeding 7 bytes should be rejected (nonce capacity)",
      "master_secret": "0102030405060708090a0b0c0d0e0f10",
      "master_salt": null,
      "sender_id": "0102030405060708",
      "recipient_id": "01",
      "expected_error": "invalid_param"
    },
    {
      "name": "invalid_ciphertext_too_short",
      "type": "invalid",
      "description": "Ciphertext shorter than tag length should be rejected",
      "ciphertext": "0102030405060708",
      "expected_error": "invalid_param"
    }
  ]
