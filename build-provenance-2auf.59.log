menuconfig LICHEN_SLIP_TRANSPORT
	bool "SLIP transport for LCI (Serial/USB)"
	depends on LICHEN && SERIAL && RING_BUFFER && NET_L2_DUMMY && NET_IPV6 && LICHEN
	help
	  Enable SLIP transport binding for the Local Client Interface (LCI).
	  Provides IPv6/CoAP connectivity over UART or USB-CDC using RFC 1055
	  SLIP framing.
	  
	  This allows standard SLIP tools (slattach, tunslip6) to communicate
	  with the mesh node using any CoAP client.
	  
	  Per LCI spec 17.3.1:
	  - Framing: END=0xC0, ESC=0xDB, ESC_END=0xDC, ESC_ESC=0xDD
	  - Node address: fe80::1
	  - Client address: fe80::2
	  - Recommended baud: 115200 or higher

